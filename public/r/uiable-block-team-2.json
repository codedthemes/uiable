         >\r\n                <Twitter className=\"size-5\" />\r\n              </a>\r\n\r\n              <a\r\n                href=\"#\"\r\n                aria-label=\"Instagram\"\r\n                className=\"flex h-10 w-10 items-center justify-center rounded-full bg-pink-100 text-pink-500 transition-all hover:scale-105 hover:bg-pink-500 hover:text-white\"\r\n              >\r\n                <Instagram className=\"size-5\" />\r\n              </a>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  );\r\n}\r\n",
