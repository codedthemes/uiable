      "content": "// shadcn\r\nimport { Avatar, AvatarFallback, AvatarImage } from \"@/components/ui/avatar\"\r\nimport { Bubble, BubbleContent, BubbleGroup } from \"@/components/ui/bubble\"\r\nimport { Message, MessageAvatar, MessageContent } from \"@/components/ui/message\"\r\n\r\n//  ------------------------------ | MESSAGE - WITH AVATAR | ------------------------------  //\r\n\r\nexport function MessageAvatars() {\r\n  return (\r\n    <div className=\"flex w-full max-w-sm flex-col gap-6\">\r\n      <Message>\r\n        <MessageAvatar>\r\n          <Avatar>\r\n            <AvatarImage\r\n              src=\"https://cdn.uiable.com/user/avatar-1.jpg\"\r\n              alt=\"@avatar\"\r\n            />\r\n            <AvatarFallback>R</AvatarFallback>\r\n          </Avatar>\r\n        </MessageAvatar>\r\n        <MessageContent>\r\n          <Bubble variant=\"muted\">\r\n            <BubbleContent>\r\n              The build failed during dependency installation.\r\n            </BubbleContent>\r\n          </Bubble>\r\n        </MessageContent>\r\n      </Message>\r\n      <Message align=\"end\">\r\n        <MessageAvatar>\r\n          <Avatar>\r\n            <AvatarImage\r\n              src=\"https://cdn.uiable.com/user/avatar-2.jpg\"\r\n              alt=\"@avatar\"\r\n            />\r\n            <AvatarFallback>R</AvatarFallback>\r\n          </Avatar>\r\n        </MessageAvatar>\r\n        <MessageContent>\r\n          <Bubble>\r\n            <BubbleContent className=\"dark:text-white\">\r\n              Can you share the exact error?\r\n            </BubbleContent>\r\n          </Bubble>\r\n        </MessageContent>\r\n      </Message>\r\n      <Message>\r\n        <MessageAvatar>\r\n          <Avatar>\r\n            <AvatarImage\r\n              src=\"https://cdn.uiable.com/user/avatar-3.jpg\"\r\n              alt=\"@avatar\"\r\n            />\r\n            <AvatarFallback>R</AvatarFallback>\r\n          </Avatar>\r\n        </MessageAvatar>\r\n        <MessageContent>\r\n          <BubbleGroup>\r\n            <Bubble variant=\"muted\">\r\n              <BubbleContent>Here&apos;s the error from the logs</BubbleContent>\r\n            </Bubble>\r\n            <Bubble variant=\"muted\">\r\n              <BubbleContent>\r\n                Something went wrong with the build. The libraries are not\r\n                installed correctly. Try running the build again.\r\n              </BubbleContent>\r\n            </Bubble>\r\n          </BubbleGroup>\r\n        </MessageContent>\r\n      </Message>\r\n    </div>\r\n  )\r\n}\r\n",
