  "files": [
    {
      "path": "src/components/uiable/command/command-groups.tsx",
      "content": "\"use client\";\r\n\r\nimport { useState } from \"react\";\r\n\r\n// shadcn\r\nimport { Button } from \"@/components/ui/button\";\r\nimport {\r\n  Command,\r\n  CommandDialog,\r\n  CommandEmpty,\r\n  CommandGroup,\r\n  CommandInput,\r\n  CommandItem,\r\n  CommandList,\r\n  CommandSeparator,\r\n  CommandShortcut\r\n} from \"@/components/ui/command\";\r\n\r\n// assets\r\nimport {\r\n  CalculatorIcon,\r\n  CalendarIcon,\r\n  CreditCardIcon,\r\n  SettingsIcon,\r\n  SmileIcon,\r\n  UserIcon\r\n} from \"lucide-react\";\r\n\r\n//  ------------------------------ | COMMAND - GROUPS | ------------------------------  //\r\n\r\nexport function CommandWithGroups() {\r\n  const [open, setOpen] = useState(false);\r\n\r\n  return (\r\n    <div className=\"flex flex-col gap-4\">\r\n      <Button onClick={() => setOpen(true)} className=\"w-fit\">\r\n        Open Menu\r\n      </Button>\r\n      <CommandDialog open={open} onOpenChange={setOpen}>\r\n        <Command>\r\n          <CommandInput placeholder=\"Type a command or search...\" />\r\n          <CommandList>\r\n            <CommandEmpty>No results found.</CommandEmpty>\r\n            <CommandGroup heading=\"Suggestions\">\r\n              <CommandItem>\r\n                <CalendarIcon />\r\n                <span>Calendar</span>\r\n              </CommandItem>\r\n              <CommandItem>\r\n                <SmileIcon />\r\n                <span>Search Emoji</span>\r\n              </CommandItem>\r\n              <CommandItem>\r\n                <CalculatorIcon />\r\n                <span>Calculator</span>\r\n              </CommandItem>\r\n            </CommandGroup>\r\n            <CommandSeparator />\r\n            <CommandGroup heading=\"Settings\">\r\n              <CommandItem>\r\n                <UserIcon />\r\n                <span>Profile</span>\r\n                <CommandShortcut>⌘P</CommandShortcut>\r\n              </CommandItem>\r\n              <CommandItem>\r\n                <CreditCardIcon />\r\n                <span>Billing</span>\r\n                <CommandShortcut>⌘B</CommandShortcut>\r\n              </CommandItem>\r\n              <CommandItem>\r\n                <SettingsIcon />\r\n                <span>Settings</span>\r\n                <CommandShortcut>⌘S</CommandShortcut>\r\n              </CommandItem>\r\n            </CommandGroup>\r\n          </CommandList>\r\n        </Command>\r\n      </CommandDialog>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/command/command-groups.tsx"
    }
  ],
  "categories": [
    "command"
  ],
  "type": "registry:ui"
}