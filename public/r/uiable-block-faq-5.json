t-base md:text-lg text-slate-800 dark:text-slate-100 group-hover:text-white transition-all\">\r\n                            <span className=\"w-6 inline-block\">\r\n                              {index + 1}.{\" \"}\r\n                            </span>\r\n                            {item.trigger}\r\n                          </p>\r\n                        </div>\r\n                        <div className=\"shrink-0\">\r\n                          <svg\r\n                            className=\"size-6 md:size-8 text-orange-500 group-aria-expanded/accordion-trigger:rotate-90 transition-all duration-300\"\r\n                            xmlns=\"http://www.w3.org/2000/svg\"\r\n                            viewBox=\"0 0 24 24\"\r\n                            fill=\"none\"\r\n                          >\r\n                            <path\r\n                              fill=\"currentColor\"\r\n                              d=\"M16.19 2H7.81C4.17 2 2 4.17 2 7.81v8.37C2 19.83 4.17 22 7.81 22h8.37c3.64 0 5.81-2.17 5.81-5.81V7.81C22 4.17 19.83 2 16.19 2z\"\r\n                              className=\"opacity-0 group-aria-expanded/accordion-trigger:opacity-15\"\r\n                            ></path>\r\n                            <path\r\n                              fill=\"currentColor\"\r\n                              d=\"M10.74 16.28c-.19 0-.38-.07-.53-.22a.754.754 0 010-1.06l3-3-3-3a.754.754 0 010-1.06c.29-.29.77-.29 1.06 0l3.53 3.53c.29.29.29.77 0 1.06l-3.53 3.53c-.15.15-.34.22-.53.22z\"\r\n                            ></path>\r\n                          </svg>\r\n                        </div>\r\n                      </div>\r\n                    </AccordionTrigger>\r\n                    <AccordionContent className=\"pt-4 pb-0 text-slate-600 dark:text-slate-300\">\r\n                      <div className=\"flex flex-col gap-4\">\r\n                        <div className=\"bg-border/40 w-full h-0.5 rounded-full\"></div>\r\n                        {item.content}\r\n                      </div>\r\n                    </AccordionContent>\r\n                  </AccordionItem>\r\n                ))}\r\n              </Accordion>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n",
