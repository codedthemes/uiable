      "content": "// assets\r\nimport { ChevronRight, Heart } from \"lucide-react\";\r\n\r\n// constants\r\nconst footerColumns = [\r\n  {\r\n    title: \"The Wedding\",\r\n    links: [\r\n      \"Our Story\",\r\n      \"Schedule of Events\",\r\n      \"Venue & Location\",\r\n      \"Bridal Party\",\r\n      \"Photo Gallery\",\r\n    ],\r\n  },\r\n  {\r\n    title: \"Guest Info\",\r\n    links: [\r\n      \"Travel & Transport\",\r\n      \"Accommodations\",\r\n      \"Dress Code\",\r\n      \"Wedding Registry\",\r\n      \"FAQs\",\r\n    ],\r\n  },\r\n  {\r\n    title: \"Registry\",\r\n    links: [\r\n      \"Honeymoon Fund\",\r\n      \"Amazon Registry\",\r\n      \"Target Registry\",\r\n      \"Crate & Barrel\",\r\n      \"Charity Donation\",\r\n    ],\r\n  },\r\n  {\r\n    title: \"RSVP & More\",\r\n    links: [\r\n      \"Online RSVP\",\r\n      \"RSVP Timeline\",\r\n      \"Guestbook\",\r\n      \"Contact Us\",\r\n      \"Privacy Policy\",\r\n    ],\r\n  },\r\n];\r\n\r\nconst socialIcons = [\r\n  {\r\n    label: \"Instagram\",\r\n    bgClass: \"hover:text-[#e1306c]\",\r\n    svg: (\r\n      <svg\r\n        className=\"h-6 w-6\"\r\n        viewBox=\"0 0 24 24\"\r\n        fill=\"none\"\r\n        stroke=\"currentColor\"\r\n        strokeWidth=\"2\"\r\n        strokeLinecap=\"round\"\r\n        strokeLinejoin=\"round\"\r\n        xmlns=\"http://www.w3.org/2000/svg\"\r\n      >\r\n        <rect x=\"2\" y=\"2\" width=\"20\" height=\"20\" rx=\"5\" ry=\"5\" />\r\n        <path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\" />\r\n        <line x1=\"17.5\" y1=\"6.5\" x2=\"17.51\" y2=\"6.5\" />\r\n      </svg>\r\n    ),\r\n  },\r\n  {\r\n    label: \"Pinterest\",\r\n    bgClass: \"hover:text-[#bd081c]\",\r\n    svg: (\r\n      <svg\r\n        className=\"h-6 w-6\"\r\n        viewBox=\"0 0 24 24\"\r\n        fill=\"currentColor\"\r\n        xmlns=\"http://www.w3.org/2000/svg\"\r\n      >\r\n        <path d=\"M12.24 2C6.51 2 2 6.51 2 12.24C2 16.63 4.7 20.39 8.57 21.94C8.47 21.12 8.37 19.86 8.57 19.01C8.75 18.2 9.77 13.88 9.77 13.88C9.77 13.88 9.46 13.25 9.46 12.33C9.46 10.89 10.3 9.81 11.35 9.81C12.28 9.81 12.73 10.51 12.73 11.35C12.73 12.28 12.14 13.68 11.83 15C11.57 16.08 12.37 16.96 13.44 16.96C15.38 16.96 16.71 14.71 16.71 11.66C16.71 9.07 14.77 7.21 12.03 7.21C8.83 7.21 6.84 9.59 6.84 12.2C6.84 13.11 7.2 14.01 7.64 14.54C7.73 14.65 7.74 14.72 7.71 14.83C7.65 15.09 7.51 15.65 7.47 15.82C7.42 16.03 7.29 16.08 7.08 15.99C5.73 15.42 5.02 13.69 5.02 12.1C5.02 8.78 7.74 5.21 12.44 5.21C16.22 5.21 18.89 7.97 18.89 11.53C18.89 15.42 16.32 18.35 12.92 18.35C11.75 18.35 10.64 17.72 10.26 17L9.77 18.87C9.59 19.56 9.14 20.42 8.77 21.02C9.83 21.34 10.96 21.51 12.13 21.51C17.86 21.51 22.5 16.87 22.5 11.14C22.4 5.4 17.84 2 12.24 2Z\" />\r\n      </svg>\r\n    ),\r\n  },\r\n  {\r\n    label: \"Facebook\",\r\n    bgClass: \"hover:text-[#1877f2]\",\r\n    svg: (\r\n      <svg\r\n        className=\"h-6 w-6\"\r\n        viewBox=\"0 0 24 24\"\r\n        fill=\"currentColor\"\r\n        xmlns=\"http://www.w3.org/2000/svg\"\r\n      >\r\n        <path d=\"M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3v3h-3v6.95c4.56-.93 8-4.96 8-9.75z\" />\r\n      </svg>\r\n    ),\r\n  },\r\n  {\r\n    label: \"Email\",\r\n    bgClass: \"hover:text-[#ea4335]\",\r\n    svg: (\r\n      <svg\r\n        className=\"h-6 w-6\"\r\n        viewBox=\"0 0 24 24\"\r\n        fill=\"none\"\r\n        stroke=\"currentColor\"\r\n        strokeWidth=\"2\"\r\n        strokeLinecap=\"round\"\r\n        strokeLinejoin=\"round\"\r\n        xmlns=\"http://www.w3.org/2000/svg\"\r\n      >\r\n        <path d=\"M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z\" />\r\n        <polyline points=\"22,6 12,13 2,6\" />\r\n      </svg>\r\n    ),\r\n  },\r\n];\r\n\r\n//  ------------------------------ | FOOTER - 5 | ------------------------------  //\r\n\r\nexport default function Footer5() {\r\n  return (\r\n    <footer className=\"overflow-hidden relative\">\r\n      <div className=\"absolute inset-0 bg-linear-to-r from-rose-400 via-pink-300 to-amber-200 z-10\"></div>\r\n      <div className=\"absolute inset-0 bg-card/85 z-20\"></div>\r\n      <div className=\"container mx-auto px-6 lg:px-8 relative z-30 py-24 sm:py-32\">\r\n        <div className=\"bg-card rounded-lg shadow-[0_0_40px_-8px_#f43f5e30] p-5 sm:p-14\">\r\n          <div className=\"grid grid-cols-12 gap-6\">\r\n            <div className=\"col-span-12 lg:col-span-3\">\r\n              <div className=\"flex flex-col gap-3 sm:gap-4\">\r\n                <div className=\"flex flex-row items-center gap-3\">\r\n                  <span className=\"text-xl sm:text-2xl font-medium tracking-wide text-slate-900 dark:text-slate-100\">\r\n                    Evie\r\n                  </span>\r\n                  <div className=\"relative flex items-center justify-center size-10 rounded-full bg-rose-50 dark:bg-rose-950/50 border border-rose-100 dark:border-rose-900/50 shadow-xs\">\r\n                    <Heart className=\"size-5 text-rose-500 fill-rose-500/30 animate-pulse\" />\r\n                  </div>\r\n                  <span className=\"text-xl sm:text-2xl font-medium tracking-wide text-slate-900 dark:text-slate-100\">\r\n                    Alex\r\n                  </span>\r\n                </div>\r\n                <p className=\"text-slate-600 dark:text-slate-400 leading-relaxed font-sans text-sm\">\r\n                  We can&apos;t wait to celebrate our special day with our\r\n                  beloved family and friends. Join us as we begin our forever.\r\n                </p>\r\n              </div>\r\n            </div>\r\n            <div className=\"col-span-12 lg:col-span-9\">\r\n              <div className=\"grid grid-cols-12 gap-6\">\r\n                {footerColumns.map((col) => (\r\n                  <div\r\n                    key={col.title}\r\n                    className=\"col-span-12 sm:col-span-6 lg:col-span-3\"\r\n                  >\r\n                    <div className=\"flex flex-col gap-3 sm:gap-6\">\r\n                      <div className=\"text-lg font-medium text-slate-900 dark:text-slate-100 \">\r\n                        {col.title}\r\n                      </div>\r\n                      <div className=\"w-full h-px bg-rose-100/50 dark:bg-rose-900/20\"></div>\r\n                      <ul className=\"space-y-2 sm:space-y-2.5\">\r\n                        {col.links.map((link) => (\r\n                          <li key={link}>\r\n                            <a\r\n                              href=\"#\"\r\n                              className=\"text-base text-slate-600 dark:text-slate-400 hover:text-rose-500 dark:hover:text-rose-300 flex items-center gap-1.5 hover:gap-2.5 hover:font-medium group transition-all duration-300 ease-in-out\"\r\n                            >\r\n                              <ChevronRight className=\"size-4 text-rose-300 dark:text-rose-700 group-hover:text-rose-500 dark:group-hover:text-rose-300 group-hover:translate-x-0.5 transition-all duration-300 ease-in-out\" />\r\n                              {link}\r\n                            </a>\r\n                          </li>\r\n                        ))}\r\n                      </ul>\r\n                    </div>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"w-full h-px bg-rose-100/50 dark:bg-rose-900/20 my-8 sm:my-10\"></div>\r\n          <div className=\"flex flex-col-reverse lg:flex-row items-center gap-4 lg:gap-6\">\r\n            <div className=\"basis-full lg:basis-2/4\">\r\n              <p className=\"text-slate-500 dark:text-slate-400 text-sm text-center lg:text-left font-sans\">\r\n                Copyright © 2026 Evie & Alex. All Rights Reserved.\r\n              </p>\r\n            </div>\r\n            <div className=\"basis-full lg:basis-2/4\">\r\n              <div className=\"flex justify-center lg:justify-end gap-3\">\r\n                {socialIcons.map(({ label, bgClass, svg }) => (\r\n                  <a\r\n                    key={label}\r\n                    href=\"#\"\r\n                    aria-label={label}\r\n                    className={`inline-flex h-9 w-9 items-center justify-center rounded-full bg-slate-50 dark:bg-slate-900 border border-slate-100 dark:border-slate-800 text-slate-500 dark:text-slate-400 ${bgClass} hover:border-rose-200 dark:hover:border-rose-900 hover:-translate-y-1 transition-all duration-300`}\r\n                  >\r\n                    {svg}\r\n                  </a>\r\n                ))}\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </footer>\r\n  );\r\n}\r\n",
