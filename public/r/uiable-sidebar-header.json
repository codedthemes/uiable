      "content": "\"use client\"\r\n\r\nimport {\r\n  DropdownMenu,\r\n  DropdownMenuContent,\r\n  DropdownMenuItem,\r\n  DropdownMenuTrigger,\r\n} from \"@/components/ui/dropdown-menu\"\r\nimport {\r\n  Sidebar,\r\n  SidebarHeader,\r\n  SidebarInset,\r\n  SidebarMenu,\r\n  SidebarMenuButton,\r\n  SidebarMenuItem,\r\n  SidebarProvider,\r\n  SidebarTrigger,\r\n} from \"@/components/ui/sidebar\"\r\nimport { ChevronDownIcon } from \"lucide-react\"\r\n\r\nexport default function AppSidebar() {\r\n  return (\r\n    <SidebarProvider className=\"relative min-h-[450px]\">\r\n      <Sidebar className=\"absolute h-[450px]\">\r\n        <SidebarHeader>\r\n          <SidebarMenu>\r\n            <SidebarMenuItem>\r\n              <DropdownMenu>\r\n                <DropdownMenuTrigger\r\n                  render={\r\n                    <SidebarMenuButton className=\"data-[state=open]:bg-sidebar-accent data-[state=open]:text-sidebar-accent-foreground\" />\r\n                  }\r\n                >\r\n                  Select Workspace\r\n                  <ChevronDownIcon className=\"ml-auto\" />\r\n                </DropdownMenuTrigger>\r\n                <DropdownMenuContent className=\"w-(--radix-popper-anchor-width)\">\r\n                  <DropdownMenuItem>\r\n                    <span>Acme Inc</span>\r\n                  </DropdownMenuItem>\r\n                  <DropdownMenuItem>\r\n                    <span>Acme Corp.</span>\r\n                  </DropdownMenuItem>\r\n                </DropdownMenuContent>\r\n              </DropdownMenu>\r\n            </SidebarMenuItem>\r\n          </SidebarMenu>\r\n        </SidebarHeader>\r\n      </Sidebar>\r\n      <SidebarInset>\r\n        <header className=\"flex h-12 items-center justify-between px-4\">\r\n          <SidebarTrigger />\r\n        </header>\r\n      </SidebarInset>\r\n    </SidebarProvider>\r\n  )\r\n}\r\n",
