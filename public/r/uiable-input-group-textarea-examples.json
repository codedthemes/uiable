      "content": "// shadcn\r\nimport {\r\n  Field,\r\n  FieldDescription,\r\n  FieldGroup,\r\n  FieldLabel\r\n} from \"@/components/ui/field\";\r\nimport {\r\n  InputGroup,\r\n  InputGroupAddon,\r\n  InputGroupButton,\r\n  InputGroupText,\r\n  InputGroupTextarea\r\n} from \"@/components/ui/input-group\";\r\nimport { Textarea } from \"@/components/ui/textarea\";\r\n\r\n// assets\r\nimport {\r\n  ArrowUpIcon,\r\n  CodeIcon,\r\n  CopyIcon,\r\n  InfoIcon,\r\n  RefreshCwIcon\r\n} from \"lucide-react\";\r\n\r\n//  ------------------------------ | INPUT GROUP - TEXTAREA EXAMPLES | ------------------------------  //\r\n\r\nexport function InputGroupTextareaExamples() {\r\n  return (\r\n    <FieldGroup>\r\n      <Field>\r\n        <FieldLabel htmlFor=\"textarea-header-footer-12\">\r\n          Default Textarea (No Input Group)\r\n        </FieldLabel>\r\n        <Textarea\r\n          id=\"textarea-header-footer-12\"\r\n          placeholder=\"Enter your text here...\"\r\n        />\r\n      </Field>\r\n      <Field>\r\n        <FieldLabel htmlFor=\"textarea-header-footer-13\">Input Group</FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea\r\n            id=\"textarea-header-footer-13\"\r\n            placeholder=\"Enter your text here...\"\r\n          />\r\n        </InputGroup>\r\n        <FieldDescription>\r\n          This is a description of the input group.\r\n        </FieldDescription>\r\n      </Field>\r\n      <Field data-invalid=\"true\">\r\n        <FieldLabel htmlFor=\"textarea-header-footer-14\">Invalid</FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea\r\n            id=\"textarea-header-footer-14\"\r\n            placeholder=\"Enter your text here...\"\r\n            aria-invalid=\"true\"\r\n          />\r\n        </InputGroup>\r\n        <FieldDescription>\r\n          This is a description of the input group.\r\n        </FieldDescription>\r\n      </Field>\r\n      <Field data-disabled=\"true\">\r\n        <FieldLabel htmlFor=\"textarea-header-footer-15\">Disabled</FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea\r\n            id=\"textarea-header-footer-15\"\r\n            placeholder=\"Enter your text here...\"\r\n            disabled\r\n          />\r\n        </InputGroup>\r\n        <FieldDescription>\r\n          This is a description of the input group.\r\n        </FieldDescription>\r\n      </Field>\r\n      <Field>\r\n        <FieldLabel htmlFor=\"prompt-31\">Addon (block-start)</FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea id=\"prompt-31\" />\r\n          <InputGroupAddon align=\"block-start\">\r\n            <InputGroupText>Ask, Search or Chat...</InputGroupText>\r\n            <InfoIcon className=\"text-muted-foreground ml-auto\" />\r\n          </InputGroupAddon>\r\n        </InputGroup>\r\n        <FieldDescription>\r\n          This is a description of the input group.\r\n        </FieldDescription>\r\n      </Field>\r\n      <Field>\r\n        <FieldLabel htmlFor=\"textarea-header-footer-30\">\r\n          Addon (block-end)\r\n        </FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea\r\n            id=\"textarea-header-footer-30\"\r\n            placeholder=\"Enter your text here...\"\r\n          />\r\n          <InputGroupAddon align=\"block-end\">\r\n            <InputGroupText>0/280 characters</InputGroupText>\r\n            <InputGroupButton\r\n              variant=\"default\"\r\n              size=\"icon-xs\"\r\n              className=\"ml-auto rounded-full\"\r\n            >\r\n              <ArrowUpIcon />\r\n              <span className=\"sr-only\">Send</span>\r\n            </InputGroupButton>\r\n          </InputGroupAddon>\r\n        </InputGroup>\r\n      </Field>\r\n      <Field>\r\n        <FieldLabel htmlFor=\"textarea-comment-31\">Addon (Buttons)</FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea\r\n            id=\"textarea-comment-31\"\r\n            placeholder=\"Share your thoughts...\"\r\n            className=\"min-h-[120px]\"\r\n          />\r\n          <InputGroupAddon align=\"block-end\">\r\n            <InputGroupButton variant=\"ghost\" className=\"ml-auto\" size=\"sm\">\r\n              Cancel\r\n            </InputGroupButton>\r\n            <InputGroupButton variant=\"default\" size=\"sm\">\r\n              Post Comment\r\n            </InputGroupButton>\r\n          </InputGroupAddon>\r\n        </InputGroup>\r\n      </Field>\r\n      <Field>\r\n        <FieldLabel htmlFor=\"textarea-code-32\">Code Editor</FieldLabel>\r\n        <InputGroup>\r\n          <InputGroupTextarea\r\n            id=\"textarea-code-32\"\r\n            placeholder=\"console.log('Hello, world!');\"\r\n            className=\"min-h-[300px] py-3\"\r\n          />\r\n          <InputGroupAddon\r\n            align=\"block-start\"\r\n            className=\"border-b border-border\"\r\n          >\r\n            <InputGroupText className=\"font-mono font-medium\">\r\n              <CodeIcon />\r\n              script.js\r\n            </InputGroupText>\r\n            <InputGroupButton size=\"icon-xs\" className=\"ml-auto\">\r\n              <RefreshCwIcon />\r\n            </InputGroupButton>\r\n            <InputGroupButton size=\"icon-xs\" variant=\"ghost\">\r\n              <CopyIcon />\r\n            </InputGroupButton>\r\n          </InputGroupAddon>\r\n          <InputGroupAddon align=\"block-end\" className=\"border-t border-border\">\r\n            <InputGroupText>Line 1, Column 1</InputGroupText>\r\n            <InputGroupText className=\"ml-auto\">JavaScript</InputGroupText>\r\n          </InputGroupAddon>\r\n        </InputGroup>\r\n      </Field>\r\n    </FieldGroup>\r\n  );\r\n}\r\n",
