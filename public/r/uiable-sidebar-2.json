  "files": [
    {
      "path": "src/components/uiable/sidebar/sidebar-2.tsx",
      "content": "\"use client\"\r\n\r\nimport { useState } from \"react\"\r\n\r\n// shadcn\r\nimport { Avatar, AvatarFallback, AvatarImage } from \"@/components/ui/avatar\"\r\nimport { Button } from \"@/components/ui/button\"\r\nimport { Card, CardContent } from \"@/components/ui/card\"\r\nimport {\r\n  Collapsible,\r\n  CollapsibleContent,\r\n  CollapsibleTrigger,\r\n} from \"@/components/ui/collapsible\"\r\nimport {\r\n  Sidebar,\r\n  SidebarContent,\r\n  SidebarGroup,\r\n  SidebarGroupContent,\r\n  SidebarGroupLabel,\r\n  SidebarHeader,\r\n  SidebarMenu,\r\n  SidebarMenuButton,\r\n  SidebarMenuItem,\r\n  SidebarMenuSub,\r\n  SidebarMenuSubButton,\r\n  SidebarMenuSubItem,\r\n  SidebarProvider,\r\n  SidebarRail,\r\n} from \"@/components/ui/sidebar\"\r\n\r\n// project\r\nimport Logo from \"@/components/uiable/layout/shared/logo\"\r\n\r\n// assets\r\nimport {\r\n  ArrowRight2,\r\n  Clipboard,\r\n  Designtools,\r\n  DocumentText,\r\n  Level,\r\n  Logout,\r\n  NotificationStatus,\r\n  PasswordCheck,\r\n  Shield,\r\n  Sort,\r\n  StatusUp,\r\n} from \"iconsax-reactjs\"\r\nimport { LockKeyhole, Power, Settings, User } from \"lucide-react\"\r\n\r\nconst imgCoupon = {\r\n  src: \"https://cdn.uiable.com/application/img-coupon.png\",\r\n}\r\nconst uImg1 = {\r\n  src: \"https://cdn.uiable.com/user/avatar-1.jpg\",\r\n}\r\n\r\n// ── Dummy data ────────────────────────────────────────────────────────────── //\r\n\r\n//  ------------------------------ | COMPONENT - SIDEBAR 2 | ------------------------------  //\r\n\r\nexport default function Sidebar2() {\r\n  const [isUserOpen, setIsUserOpen] = useState(false)\r\n  const [activeItem, setActiveItem] = useState(\"dashboard\")\r\n\r\n  return (\r\n    <SidebarProvider className=\"relative h-[600px] w-full overflow-hidden rounded-lg border bg-background\">\r\n      <Sidebar\r\n        collapsible=\"icon\"\r\n        variant=\"inset\"\r\n        className=\"absolute z-10 h-full border-r border-dashed border-border\"\r\n      >\r\n        <SidebarHeader className=\"px-4 pt-4 pb-2\">\r\n          <SidebarMenu>\r\n            <SidebarMenuItem>\r\n              <Logo />\r\n            </SidebarMenuItem>\r\n          </SidebarMenu>\r\n        </SidebarHeader>\r\n\r\n        <SidebarContent className=\"gap-0 px-2 *:py-0\">\r\n          {/* User Profile Card */}\r\n          <Card className=\"m-1.75 bg-[#f3f5f7] shadow-none dark:bg-[#1b232d]\">\r\n            <CardContent className=\"p-5!\">\r\n              <Collapsible\r\n                open={isUserOpen}\r\n                onOpenChange={setIsUserOpen}\r\n                className=\"flex flex-col gap-2\"\r\n              >\r\n                <div className=\"flex items-center gap-3\">\r\n                  <Avatar className=\"h-10 w-10 border-2 border-background\">\r\n                    <AvatarImage src={uImg1.src} alt=\"User\" />\r\n                    <AvatarFallback className=\"bg-primary/10 font-bold text-primary\">\r\n                      JS\r\n                    </AvatarFallback>\r\n                  </Avatar>\r\n                  <div className=\"flex flex-1 flex-col\">\r\n                    <h6 className=\"mb-0\">John Smith</h6>\r\n                    <small className=\"text-muted-foreground\">\r\n                      Administrator\r\n                    </small>\r\n                  </div>\r\n                  <CollapsibleTrigger\r\n                    render={\r\n                      <Button variant=\"ghost\" size=\"icon\">\r\n                        <Sort className=\"size-5.5\" />\r\n                      </Button>\r\n                    }\r\n                  />\r\n                </div>\r\n                <CollapsibleContent>\r\n                  <div className=\"pt-3 *:flex *:items-center *:gap-2.5 *:py-2 *:last:pb-0 *:hover:text-primary\">\r\n                    <a href=\"#!\">\r\n                      <User className=\"size-4\" />\r\n                      <span>My Account</span>\r\n                    </a>\r\n                    <a href=\"#!\">\r\n                      <Settings className=\"size-4\" />\r\n                      <span>Settings</span>\r\n                    </a>\r\n                    <a href=\"#!\">\r\n                      <LockKeyhole className=\"size-4\" />\r\n                      <span>Lock Screen</span>\r\n                    </a>\r\n                    <a href=\"#!\">\r\n                      <Power className=\"size-4\" />\r\n                      <span>Logout</span>\r\n                    </a>\r\n                  </div>\r\n                </CollapsibleContent>\r\n              </Collapsible>\r\n            </CardContent>\r\n          </Card>\r\n\r\n          {/* Dashboard */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"px-5.5 pt-6 pb-2 text-[10px] font-bold tracking-widest text-muted-foreground/70 uppercase\">\r\n              Dashboard\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"dashboard\"}\r\n                    onClick={() => setActiveItem(\"dashboard\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <StatusUp className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Default</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Authentication */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"px-5.5 pt-6 pb-2 text-[10px] font-bold tracking-widest text-muted-foreground/70 uppercase\">\r\n              Authentication\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"login\"}\r\n                    onClick={() => setActiveItem(\"login\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <Shield className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Login</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"register\"}\r\n                    onClick={() => setActiveItem(\"register\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <PasswordCheck className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Register</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Components */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"px-5.5 pt-6 pb-2 text-[10px] font-bold tracking-widest text-muted-foreground/70 uppercase\">\r\n              Components\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"components\"}\r\n                    onClick={() => setActiveItem(\"components\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <Clipboard className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Components</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"blocks\"}\r\n                    onClick={() => setActiveItem(\"blocks\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <Designtools className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Blocks</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Extra */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"px-5.5 pt-6 pb-2 text-[10px] font-bold tracking-widest text-muted-foreground/70 uppercase\">\r\n              Extra\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"docs\"}\r\n                    onClick={() => setActiveItem(\"docs\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <DocumentText className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Documentation</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n              <SidebarMenu>\r\n                <Collapsible className=\"group/collapsible\">\r\n                  <SidebarMenuItem>\r\n                    <CollapsibleTrigger\r\n                      render={\r\n                        <SidebarMenuButton\r\n                          tooltip=\"Menu levels\"\r\n                          className=\"rounded-lg px-5 py-3.5\"\r\n                        />\r\n                      }\r\n                    >\r\n                      <Level className=\"size-5.5!\" variant=\"Bulk\" />\r\n                      <span className=\"font-medium\">Menu levels</span>\r\n                      <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible:rotate-90\" />\r\n                    </CollapsibleTrigger>\r\n                    <CollapsibleContent>\r\n                      <SidebarMenuSub>\r\n                        <SidebarMenuSubItem>\r\n                          <SidebarMenuSubButton>\r\n                            <span>Level 2.1</span>\r\n                          </SidebarMenuSubButton>\r\n                        </SidebarMenuSubItem>\r\n                        <Collapsible className=\"group/collapsible-2\">\r\n                          <SidebarMenuSubItem>\r\n                            <CollapsibleTrigger\r\n                              nativeButton={false}\r\n                              render={\r\n                                <SidebarMenuSubButton className=\"flex w-full justify-between\" />\r\n                              }\r\n                            >\r\n                              <span>Level 2.2</span>\r\n                              <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-2:rotate-90\" />\r\n                            </CollapsibleTrigger>\r\n                            <CollapsibleContent>\r\n                              <SidebarMenuSub className=\"mt-1 ml-2 border-l border-border/50 pl-2\">\r\n                                <SidebarMenuSubItem>\r\n                                  <SidebarMenuSubButton>\r\n                                    <span>Level 3.1</span>\r\n                                  </SidebarMenuSubButton>\r\n                                </SidebarMenuSubItem>\r\n                                <Collapsible className=\"group/collapsible-3\">\r\n                                  <SidebarMenuSubItem>\r\n                                    <CollapsibleTrigger\r\n                                      nativeButton={false}\r\n                                      render={\r\n                                        <SidebarMenuSubButton className=\"flex w-full justify-between\" />\r\n                                      }\r\n                                    >\r\n                                      <span>Level 3.2</span>\r\n                                      <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-3:rotate-90\" />\r\n                                    </CollapsibleTrigger>\r\n                                    <CollapsibleContent>\r\n                                      <SidebarMenuSub className=\"mt-1 ml-2 border-l border-border/50 pl-2\">\r\n                                        <SidebarMenuSubItem>\r\n                                          <SidebarMenuSubButton>\r\n                                            <span>Level 4.1</span>\r\n                                          </SidebarMenuSubButton>\r\n                                        </SidebarMenuSubItem>\r\n                                        <SidebarMenuSubItem>\r\n                                          <SidebarMenuSubButton>\r\n                                            <span>Level 4.2</span>\r\n                                          </SidebarMenuSubButton>\r\n                                        </SidebarMenuSubItem>\r\n                                        <SidebarMenuSubItem>\r\n                                          <SidebarMenuSubButton>\r\n                                            <span>Level 4.3</span>\r\n                                          </SidebarMenuSubButton>\r\n                                        </SidebarMenuSubItem>\r\n                                      </SidebarMenuSub>\r\n                                    </CollapsibleContent>\r\n                                  </SidebarMenuSubItem>\r\n                                </Collapsible>\r\n                                <Collapsible className=\"group/collapsible-4\">\r\n                                  <SidebarMenuSubItem>\r\n                                    <CollapsibleTrigger\r\n                                      nativeButton={false}\r\n                                      render={\r\n                                        <SidebarMenuSubButton className=\"flex w-full justify-between\" />\r\n                                      }\r\n                                    >\r\n                                      <span>Level 3.3</span>\r\n                                      <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-4:rotate-90\" />\r\n                                    </CollapsibleTrigger>\r\n                                    <CollapsibleContent>\r\n                                      <SidebarMenuSub className=\"mt-1 ml-2 border-l border-border/50 pl-2\">\r\n                                        <SidebarMenuSubItem>\r\n                                          <SidebarMenuSubButton>\r\n                                            <span>Level 4.1</span>\r\n                                          </SidebarMenuSubButton>\r\n                                        </SidebarMenuSubItem>\r\n                                        <SidebarMenuSubItem>\r\n                                          <SidebarMenuSubButton>\r\n                                            <span>Level 4.2</span>\r\n                                          </SidebarMenuSubButton>\r\n                                        </SidebarMenuSubItem>\r\n                                        <SidebarMenuSubItem>\r\n                                          <SidebarMenuSubButton>\r\n                                            <span>Level 4.3</span>\r\n                                          </SidebarMenuSubButton>\r\n                                        </SidebarMenuSubItem>\r\n                                      </SidebarMenuSub>\r\n                                    </CollapsibleContent>\r\n                                  </SidebarMenuSubItem>\r\n                                </Collapsible>\r\n                              </SidebarMenuSub>\r\n                            </CollapsibleContent>\r\n                          </SidebarMenuSubItem>\r\n                        </Collapsible>\r\n                        <SidebarMenuSubItem>\r\n                          <SidebarMenuSubButton>\r\n                            <span>Level 2.3</span>\r\n                          </SidebarMenuSubButton>\r\n                        </SidebarMenuSubItem>\r\n                      </SidebarMenuSub>\r\n                    </CollapsibleContent>\r\n                  </SidebarMenuItem>\r\n                </Collapsible>\r\n              </SidebarMenu>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"sample\"}\r\n                    onClick={() => setActiveItem(\"sample\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <NotificationStatus className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Sample Page</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Upgrade Card */}\r\n          <Card className=\"mx-1.75 my-3.75 shadow-none\">\r\n            <CardContent className=\"text-center\">\r\n              <img\r\n                src={imgCoupon.src}\r\n                alt=\"coupon\"\r\n                className=\"mx-auto w-2/4 max-w-full\"\r\n              />\r\n              <h5 className=\"mt-1 mb-0\">UIAble</h5>\r\n              <p className=\"mb-4\">Checkout pro features</p>\r\n              <Button className=\"gap-2 bg-yellow-500 hover:bg-yellow-600\">\r\n                <Logout />\r\n                Upgrade to Pro\r\n              </Button>\r\n            </CardContent>\r\n          </Card>\r\n        </SidebarContent>\r\n        <SidebarRail />\r\n      </Sidebar>\r\n    </SidebarProvider>\r\n  )\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/sidebar/sidebar-2.tsx"
    }
