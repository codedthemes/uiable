  "files": [
    {
      "path": "src/components/uiable/blocks/layout/doc-layout/DocLayout.tsx",
      "content": "\"use client\";\r\n\r\nimport { useState } from \"react\";\r\n\r\n// shadcn\r\nimport { Button } from \"@/components/ui/button\";\r\nimport {\r\n  Collapsible,\r\n  CollapsibleContent,\r\n  CollapsibleTrigger\r\n} from \"@/components/ui/collapsible\";\r\nimport {\r\n  Sidebar,\r\n  SidebarContent,\r\n  SidebarGroup,\r\n  SidebarGroupContent,\r\n  SidebarGroupLabel,\r\n  SidebarHeader,\r\n  SidebarInset,\r\n  SidebarMenu,\r\n  SidebarMenuButton,\r\n  SidebarMenuItem,\r\n  SidebarProvider,\r\n  SidebarRail,\r\n  SidebarTrigger\r\n} from \"@/components/ui/sidebar\";\r\n\r\n// project\r\nimport NotificationDropdown from \"@/components/uiable/layout/notification-dropdown\";\r\nimport SearchBar from \"@/components/uiable/layout/search-bar\";\r\nimport Logo from \"@/components/uiable/layout/shared/logo\";\r\nimport UserProfile from \"@/components/uiable/layout/user-profile\";\r\n\r\n// assets\r\nimport { ArrowLeft, ChevronDown, Settings } from \"lucide-react\";\r\n\r\n// ── Dummy data ────────────────────────────────────────────────────────────── //\r\n\r\nconst DUMMY_DOC_LINKS = [\r\n  { title: \"Introduction\" },\r\n  { title: \"Installation\" },\r\n  { title: \"Components\" },\r\n  { title: \"Blocks\" },\r\n  { title: \"Figma\" },\r\n  { title: \"License\" }\r\n];\r\n\r\nconst DUMMY_BLOCKS = [\r\n  { title: \"Hero\", count: 12 },\r\n  { title: \"Feature\", count: 8 },\r\n  { title: \"CTA\", count: 5 },\r\n  { title: \"Footer\", count: 10 }\r\n];\r\n\r\nconst DUMMY_COMPONENTS = [\r\n  { title: \"Accordion\", count: 3 },\r\n  { title: \"Button\", count: 15 },\r\n  { title: \"Dialog\", count: 7 },\r\n  { title: \"Tabs\", count: 4 }\r\n];\r\n\r\n//  ------------------------------ | BLOCK - DOC LAYOUT | ------------------------------  //\r\n\r\nexport default function DocLayout() {\r\n  const [activeItem, setActiveItem] = useState(\"Introduction\");\r\n\r\n  return (\r\n    <SidebarProvider className=\"w-full h-[600px] min-h-0! relative overflow-hidden bg-background\">\r\n      {/* ── Sidebar ── */}\r\n      <Sidebar\r\n        collapsible=\"offcanvas\"\r\n        variant=\"inset\"\r\n        className=\"absolute h-full z-10 border-r border-dashed\"\r\n      >\r\n        <SidebarHeader className=\"pt-4 px-4 pb-2\">\r\n          <SidebarMenu>\r\n            <SidebarMenuItem>\r\n              <Logo />\r\n            </SidebarMenuItem>\r\n          </SidebarMenu>\r\n        </SidebarHeader>\r\n\r\n        <SidebarContent className=\"px-2 gap-0 *:py-0\">\r\n          {/* Documentation Section */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"pt-6 pb-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n              Documentation\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                {DUMMY_DOC_LINKS.map((doc) => (\r\n                  <SidebarMenuItem key={doc.title}>\r\n                    <SidebarMenuButton\r\n                      isActive={activeItem === doc.title}\r\n                      onClick={() => setActiveItem(doc.title)}\r\n                      tooltip={doc.title}\r\n                      className=\"rounded-lg px-4 py-2 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                    >\r\n                      <span className=\"font-medium\">{doc.title}</span>\r\n                    </SidebarMenuButton>\r\n                  </SidebarMenuItem>\r\n                ))}\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Blocks Collapsible Section */}\r\n          <SidebarGroup className=\"flex flex-col gap-1\">\r\n            <Collapsible\r\n              className=\"data-open:bg-background rounded-[20px]\"\r\n              defaultOpen\r\n            >\r\n              <CollapsibleTrigger\r\n                render={\r\n                  <Button\r\n                    variant=\"ghost\"\r\n                    className=\"w-full hover:bg-background aria-expanded:bg-background p-0 pt-6 pb-2\"\r\n                  />\r\n                }\r\n              >\r\n                <SidebarGroupLabel className=\"text-[10px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n                  Block\r\n                </SidebarGroupLabel>\r\n                <ChevronDown className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible:rotate-180\" />\r\n              </CollapsibleTrigger>\r\n              <CollapsibleContent className=\"flex flex-col items-start\">\r\n                <SidebarGroupContent>\r\n                  <SidebarMenu>\r\n                    {DUMMY_BLOCKS.map((item) => (\r\n                      <SidebarMenuItem key={item.title}>\r\n                        <SidebarMenuButton\r\n                          isActive={activeItem === item.title}\r\n                          onClick={() => setActiveItem(item.title)}\r\n                          className=\"rounded-lg px-4 py-2 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                        >\r\n                          <span className=\"font-medium\">{item.title}</span>\r\n                          <span className=\"size-5.5 rounded-sm inline-flex items-center justify-center text-[11px] opacity-80 ml-auto bg-primary/10 text-primary\">\r\n                            {item.count}\r\n                          </span>\r\n                        </SidebarMenuButton>\r\n                      </SidebarMenuItem>\r\n                    ))}\r\n                  </SidebarMenu>\r\n                </SidebarGroupContent>\r\n              </CollapsibleContent>\r\n            </Collapsible>\r\n          </SidebarGroup>\r\n\r\n          {/* UI Components Collapsible Section */}\r\n          <SidebarGroup className=\"flex flex-col gap-1\">\r\n            <Collapsible className=\"data-open:bg-background rounded-[20px]\">\r\n              <CollapsibleTrigger\r\n                render={\r\n                  <Button\r\n                    variant=\"ghost\"\r\n                    className=\"w-full hover:bg-background aria-expanded:bg-background p-0 pt-6 pb-2\"\r\n                  />\r\n                }\r\n              >\r\n                <SidebarGroupLabel className=\"text-[11px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n                  UI Components\r\n                </SidebarGroupLabel>\r\n                <ChevronDown className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible:rotate-180\" />\r\n              </CollapsibleTrigger>\r\n              <CollapsibleContent className=\"flex flex-col items-start\">\r\n                <SidebarGroupContent>\r\n                  <SidebarMenu>\r\n                    {DUMMY_COMPONENTS.map((item) => (\r\n                      <SidebarMenuItem key={item.title}>\r\n                        <SidebarMenuButton\r\n                          isActive={activeItem === item.title}\r\n                          onClick={() => setActiveItem(item.title)}\r\n                          className=\"rounded-lg px-4 py-2 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                        >\r\n                          <span className=\"font-medium\">{item.title}</span>\r\n                          <span className=\"size-5.5 rounded-sm inline-flex items-center justify-center text-[11px] opacity-80 ml-auto bg-primary/10 text-primary\">\r\n                            {item.count}\r\n                          </span>\r\n                        </SidebarMenuButton>\r\n                      </SidebarMenuItem>\r\n                    ))}\r\n                  </SidebarMenu>\r\n                </SidebarGroupContent>\r\n              </CollapsibleContent>\r\n            </Collapsible>\r\n          </SidebarGroup>\r\n\r\n          {/* Navigation Section */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"pt-6 pb-2 text-[10px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n              Navigation\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton className=\"rounded-lg px-4 py-2 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\">\r\n                    <ArrowLeft className=\"size-4!\" />\r\n                    <span className=\"font-medium\">Back to Dashboard</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n        </SidebarContent>\r\n\r\n        <SidebarRail />\r\n      </Sidebar>\r\n\r\n      {/* ── Main content with Navbar ── */}\r\n      <SidebarInset className=\"flex flex-col overflow-hidden\">\r\n        {/* ── Navbar ── */}\r\n        <header className=\"flex h-16 w-full shrink-0 items-center gap-1 bg-background/80 backdrop-blur-md border-b border-border/50 px-4 sm:px-6\">\r\n          <SidebarTrigger className=\"-ml-1 w-11 h-11 rounded-lg relative flex items-center justify-center mx-1\" />\r\n          <SearchBar />\r\n          <div className=\"flex-1\" />\r\n          <div className=\"flex items-center gap-2 sm:gap-4\">\r\n            <Button\r\n              variant=\"ghost\"\r\n              className=\"inline-flex items-center justify-center h-9 w-9 rounded-lg border border-transparent text-muted-foreground hover:bg-muted hover:text-primary transition-colors\"\r\n            >\r\n              <Settings className=\"size-5\" />\r\n            </Button>\r\n            <div className=\"h-4 w-px bg-border mx-1\" />\r\n            <NotificationDropdown />\r\n            <div className=\"h-4 w-px bg-border mx-1\" />\r\n            <UserProfile />\r\n          </div>\r\n        </header>\r\n\r\n        {/* ── Page content ── */}\r\n        <div className=\"flex-1 overflow-y-auto\">\r\n          <div className=\"flex flex-col gap-4 p-4\">\r\n            <div className=\"grid auto-rows-min gap-4 md:grid-cols-3\">\r\n              <div className=\"aspect-video rounded-xl bg-card\" />\r\n              <div className=\"aspect-video rounded-xl bg-card\" />\r\n              <div className=\"aspect-video rounded-xl bg-card\" />\r\n            </div>\r\n            <div className=\"min-h-40 rounded-xl bg-card\" />\r\n          </div>\r\n        </div>\r\n      </SidebarInset>\r\n    </SidebarProvider>\r\n  );\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/blocks/layout/doc-layout/DocLayout.tsx"
    }
  ],
  "categories": [
    "doc-layout"
  ],
  "type": "registry:block"
}