Name=\"col-span-6\">\r\n                      <FieldLabel htmlFor=\"fieldgroup-lname\">\r\n                        Last Name\r\n                      </FieldLabel>\r\n                      <Input id=\"fieldgroup-lname\" placeholder=\"Lee\" />\r\n                    </Field>\r\n                  </div>\r\n                  <Field>\r\n                    <FieldLabel htmlFor=\"fieldgroup-email\">Email</FieldLabel>\r\n                    <Input\r\n                      id=\"fieldgroup-email\"\r\n                      type=\"email\"\r\n                      placeholder=\"name@example.com\"\r\n                    />\r\n                  </Field>\r\n                  <Field>\r\n                    <FieldLabel htmlFor=\"textarea-header-footer-12\">\r\n                      Messege\r\n                    </FieldLabel>\r\n                    <Textarea\r\n                      id=\"textarea-header-footer-12\"\r\n                      placeholder=\"Enter your text here...\"\r\n                    />\r\n                  </Field>\r\n                  <Field orientation=\"horizontal\" className=\"justify-center\">\r\n                    <Button type=\"reset\" variant=\"outline\" className=\"bg-card\">\r\n                      Reset\r\n                    </Button>\r\n                    <Button type=\"submit\">Get Started</Button>\r\n                  </Field>\r\n                </FieldGroup>\r\n              </div>\r\n              <div className=\"w-full basis-full lg:basis-7/12 text-center\">\r\n                <div className=\"flex flex-col gap-4 lg:flex-row items-center\">\r\n                  <div className=\"w-full basis-full lg:basis-6/12 text-center\">\r\n                    <div className=\"group px-6 py-10 bg-background hover:bg-pink-500 rounded-2xl transition-all\">\r\n                      <div className=\"flex flex-col gap-6\">\r\n                        <h2 className=\"text-md sm:text-2xl font-medium text-slate-800 dark:text-slate-100 group-hover:text-white transition-all\">\r\n                          Contact Us\r\n                        </h2>\r\n                        <div className=\"size-30 bg-pink-500 text-white group-hover:bg-white group-hover:text-pink-500 transition-all rounded-full inline-flex items-center justify-center mx-auto\">\r\n                          <svg\r\n                            className=\"size-16\"\r\n                            xmlns=\"http://www.w3.org/2000/svg\"\r\n                            viewBox=\"0 0 24 24\"\r\n                            fill=\"none\"\r\n                          >\r\n                            <path\r\n                              d=\"M6 13c-2.76 0-5 2.23-5 5s2.24 5 5 5 5-2.24 5-5-2.23-5-5-5Zm-2.04 2.96H6a.68.68 0 0 1 0 1.36H3.96a.68.68 0 0 1 0-1.36Zm4.08 4.08H3.96a.68.68 0 0 1-.68-.68c0-.37.31-.68.68-.68h4.09c.38 0 .68.31.68.68 0 .37-.31.68-.69.68Z\"\r\n                              fill=\"currentColor\"\r\n                            ></path>\r\n                            <path\r\n                              d=\"M17 3H7C4 3 2 4.5 2 8v3.14c0 .73.75 1.19 1.42.9a6.51 6.51 0 0 1 3.66-.45c2.62.43 4.76 2.5 5.29 5.1.15.76.17 1.5.07 2.21-.08.59.4 1.11.99 1.11H17c3 0 5-1.5 5-5V8c0-3.5-2-5-5-5Zm.47 5.59-3.13 2.5c-.66.53-1.5.79-2.34.79-.84 0-1.69-.26-2.34-.79l-3.13-2.5a.77.77 0 0 1-.12-1.06c.26-.32.73-.38 1.05-.12l3.13 2.5c.76.61 2.05.61 2.81 0l3.13-2.5c.32-.26.8-.21 1.05.12.26.32.21.8-.11 1.06Z\"\r\n                              fill=\"currentColor\"\r\n                            ></path>\r\n                          </svg>\r\n                        </div>\r\n                        <div className=\"flex flex-col gap-1\">\r\n                          <p className=\"text-md sm:text-lg text-slate-800 dark:text-slate-100 group-hover:text-white transition-all\">\r\n                            Email\r\n                          </p>\r\n                          <a href=\"mailto:contact@example.com\">\r\n                            <p className=\"text-slate-600 dark:text-sla