      "path": "src/components/uiable/blocks/layout/auth-layout/Login.tsx",
      "content": "import Link from \"next/link\";\r\n\r\n// shadcn\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Card, CardContent } from \"@/components/ui/card\";\r\nimport { Checkbox } from \"@/components/ui/checkbox\";\r\nimport { Input } from \"@/components/ui/input\";\r\n\r\n// project\r\nimport Logo from \"@/components/uiable/layout/shared/logo\";\r\n\r\n//  ------------------------------ | LOGIN | ------------------------------  //\r\n\r\nexport default function Login() {\r\n  return (\r\n    <div className=\"min-h-screen w-full flex items-center justify-center px-4 py-10 bg-[url('https://cdn.uiable.com/authentication/img-auth-bg.jpg')] bg-cover bg-center dark:bg-[url('https://cdn.uiable.com/authentication/img-auth-bg-dark.jpg')]\">\r\n      <Card className=\"w-full max-w-md shadow-none\">\r\n        <CardContent className=\"space-y-4 p-6 sm:p-10\">\r\n          <div className=\"text-center\">\r\n            <Logo className=\"mb-2 justify-center\" />\r\n          </div>\r\n\r\n          {/* Email Login Heading */}\r\n          <div className=\"text-center mb-4\">\r\n            <h4 className=\"text-center font-medium mb-4\">\r\n              Login with your email\r\n            </h4>\r\n          </div>\r\n\r\n          {/* Login Form */}\r\n          <div className=\"grid gap-0\">\r\n            <div className=\"grid gap-2 mb-3\">\r\n              <Input\r\n                id=\"email\"\r\n                type=\"email\"\r\n                placeholder=\"Email Address\"\r\n                required\r\n              />\r\n            </div>\r\n            <div className=\"grid gap-2 mb-4\">\r\n              <Input\r\n                id=\"password\"\r\n                type=\"password\"\r\n                placeholder=\"Password\"\r\n                required\r\n              />\r\n            </div>\r\n            <div className=\"flex items-center justify-between mt-1 flex-wrap gap-2\">\r\n              <div className=\"flex items-center space-x-2\">\r\n                <Checkbox\r\n                  id=\"remember\"\r\n                  className=\"border-[#bec8d0] data-[state=checked]:bg-primary data-[state=checked]:border-primary rounded\"\r\n                  defaultChecked\r\n                />\r\n                <label\r\n                  htmlFor=\"remember\"\r\n                  className=\"peer-disabled:cursor-not-allowed peer-disabled:opacity-70\"\r\n                >\r\n                  Remember me?\r\n                </label>\r\n              </div>\r\n              <Link href=\"\" className=\"text-primary\">\r\n                Forgot Password?\r\n              </Link>\r\n            </div>\r\n            <Button className=\"w-full mt-4\">Login</Button>\r\n          </div>\r\n          <div className=\"flex justify-between items-end flex-wrap gap-2 mt-4\">\r\n            <h6 className=\"f-w-500 mb-0\">Don't have an Account?</h6>\r\n            <Link href=\"\" className=\"text-primary\">\r\n              Create Account\r\n            </Link>\r\n          </div>\r\n        </CardContent>\r\n      </Card>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/blocks/layout/auth-layout/Login.tsx"
    }
  ],
  "categories": [
    "auth-layout"
  ],
  "type": "registry:block"
