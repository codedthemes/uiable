  "files": [
    {
      "path": "src/components/uiable/blocks/layout/dashboard-layout/Dashboard.tsx",
      "content": "\"use client\";\r\n\r\nimport { useState } from \"react\";\r\n\r\n// shadcn\r\nimport { Avatar, AvatarFallback, AvatarImage } from \"@/components/ui/avatar\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Card, CardContent } from \"@/components/ui/card\";\r\nimport {\r\n  Collapsible,\r\n  CollapsibleContent,\r\n  CollapsibleTrigger,\r\n} from \"@/components/ui/collapsible\";\r\nimport {\r\n  Sidebar,\r\n  SidebarContent,\r\n  SidebarGroup,\r\n  SidebarGroupContent,\r\n  SidebarGroupLabel,\r\n  SidebarHeader,\r\n  SidebarInset,\r\n  SidebarMenu,\r\n  SidebarMenuButton,\r\n  SidebarMenuItem,\r\n  SidebarMenuSub,\r\n  SidebarMenuSubButton,\r\n  SidebarMenuSubItem,\r\n  SidebarProvider,\r\n  SidebarRail,\r\n  SidebarTrigger,\r\n} from \"@/components/ui/sidebar\";\r\n\r\n// project\r\nimport NotificationDropdown from \"@/components/uiable/layout/notification-dropdown\";\r\nimport SearchBar from \"@/components/uiable/layout/search-bar\";\r\nimport Logo from \"@/components/uiable/layout/shared/logo\";\r\nimport UserProfile from \"@/components/uiable/layout/user-profile\";\r\n\r\n// assets\r\nimport {\r\n  ArrowRight2,\r\n  DocumentText,\r\n  Level,\r\n  Logout,\r\n  NotificationStatus,\r\n  PasswordCheck,\r\n  Shield,\r\n  Sort,\r\n  StatusUp,\r\n} from \"iconsax-reactjs\";\r\nimport { LockKeyhole, Power, Settings, User } from \"lucide-react\";\r\n\r\nconst imgCoupon = {\r\n  src: \"https://cdn.uiable.com/application/img-coupon.png\",\r\n};\r\nconst uImg1 = {\r\n  src: \"https://cdn.uiable.com/user/avatar-1.jpg\",\r\n};\r\n\r\n//  ------------------------------ | BLOCK - DASHBOARD LAYOUT | ------------------------------  //\r\n\r\nexport default function Dashboard() {\r\n  const [isUserOpen, setIsUserOpen] = useState(false);\r\n  const [activeItem, setActiveItem] = useState(\"dashboard\");\r\n\r\n  return (\r\n    <SidebarProvider className=\"w-full h-[600px] min-h-0! relative overflow-hidden bg-background has-[data-slot='sidebar-inset']:shadow-none\">\r\n      <Sidebar\r\n        collapsible=\"offcanvas\"\r\n        variant=\"inset\"\r\n        className=\"absolute h-full z-10 border-r border-dashed\"\r\n      >\r\n        <SidebarHeader className=\"pt-4 px-4 pb-2\">\r\n          <SidebarMenu>\r\n            <SidebarMenuItem>\r\n              <Logo />\r\n            </SidebarMenuItem>\r\n          </SidebarMenu>\r\n        </SidebarHeader>\r\n\r\n        <SidebarContent className=\"px-2 gap-0 *:py-0\">\r\n          {/* User Profile Card */}\r\n          <Card className=\"m-1.75 shadow-none bg-muted\">\r\n            <CardContent className=\"p-5!\">\r\n              <Collapsible\r\n                open={isUserOpen}\r\n                onOpenChange={setIsUserOpen}\r\n                className=\"flex flex-col gap-2\"\r\n              >\r\n                <div className=\"flex items-center gap-3\">\r\n                  <Avatar className=\"h-10 w-10 border-2 border-background\">\r\n                    <AvatarImage src={uImg1.src} alt=\"User\" />\r\n                    <AvatarFallback className=\"bg-primary/10 text-primary font-bold\">\r\n                      JS\r\n                    </AvatarFallback>\r\n                  </Avatar>\r\n                  <div className=\"flex flex-col flex-1\">\r\n                    <h6 className=\"mb-0\">John Smith</h6>\r\n                    <small className=\"text-muted-foreground\">\r\n                      Administrator\r\n                    </small>\r\n                  </div>\r\n                  <CollapsibleTrigger\r\n                    render={\r\n                      <Button variant=\"ghost\" size=\"icon\">\r\n                        <Sort className=\"size-5.5\" />\r\n                      </Button>\r\n                    }\r\n                  />\r\n                </div>\r\n                <CollapsibleContent>\r\n                  <div className=\"pt-3 *:flex *:items-center *:py-2 *:gap-2.5 *:hover:text-primary *:last:pb-0\">\r\n                    <a href=\"#!\">\r\n                      <User className=\"size-4\" />\r\n                      <span>My Account</span>\r\n                    </a>\r\n                    <a href=\"#!\">\r\n                      <Settings className=\"size-4\" />\r\n                      <span>Settings</span>\r\n                    </a>\r\n                    <a href=\"#!\">\r\n                      <LockKeyhole className=\"size-4\" />\r\n                      <span>Lock Screen</span>\r\n                    </a>\r\n                    <a href=\"#!\">\r\n                      <Power className=\"size-4\" />\r\n                      <span>Logout</span>\r\n                    </a>\r\n                  </div>\r\n                </CollapsibleContent>\r\n              </Collapsible>\r\n            </CardContent>\r\n          </Card>\r\n\r\n          {/* Dashboard */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"pt-6 pb-2 px-5.5 text-[10px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n              Dashboard\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"dashboard\"}\r\n                    onClick={() => setActiveItem(\"dashboard\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <StatusUp className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Default</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Authentication */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"pt-6 pb-2 px-5.5 text-[10px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n              Authentication\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"login\"}\r\n                    onClick={() => setActiveItem(\"login\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <Shield className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Login</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"register\"}\r\n                    onClick={() => setActiveItem(\"register\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <PasswordCheck className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Register</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Extra */}\r\n          <SidebarGroup>\r\n            <SidebarGroupLabel className=\"pt-6 pb-2 px-5.5 text-[10px] font-bold uppercase tracking-widest text-muted-foreground/70\">\r\n              Extra\r\n            </SidebarGroupLabel>\r\n            <SidebarGroupContent>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"docs\"}\r\n                    onClick={() => setActiveItem(\"docs\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <DocumentText className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Documentation</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n\r\n                <SidebarMenu>\r\n                  <Collapsible className=\"group/collapsible\">\r\n                    <SidebarMenuItem>\r\n                      <CollapsibleTrigger\r\n                        render={\r\n                          <SidebarMenuButton\r\n                            tooltip=\"Menu levels\"\r\n                            className=\"rounded-lg px-5 py-3.5\"\r\n                          />\r\n                        }\r\n                      >\r\n                        <Level className=\"size-5.5!\" variant=\"Bulk\" />\r\n                        <span className=\"font-medium\">Menu levels</span>\r\n                        <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible:rotate-90\" />\r\n                      </CollapsibleTrigger>\r\n                      <CollapsibleContent>\r\n                        <SidebarMenuSub>\r\n                          {/* Level 2.1 */}\r\n                          <SidebarMenuSubItem>\r\n                            <SidebarMenuSubButton>\r\n                              <span>Level 2.1</span>\r\n                            </SidebarMenuSubButton>\r\n                          </SidebarMenuSubItem>\r\n\r\n                          {/* Level 2.2 with 3.1, 3.2, 3.3 (with 4.1, 4.2) */}\r\n                          <Collapsible className=\"group/collapsible-2\">\r\n                            <SidebarMenuSubItem>\r\n                              <CollapsibleTrigger\r\n                                nativeButton={false}\r\n                                render={\r\n                                  <SidebarMenuSubButton className=\"w-full flex justify-between\" />\r\n                                }\r\n                              >\r\n                                <span>Level 2.2</span>\r\n                                <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-2:rotate-90\" />\r\n                              </CollapsibleTrigger>\r\n                              <CollapsibleContent>\r\n                                <SidebarMenuSub className=\"ml-2 border-l border-border/50 pl-2 mt-1\">\r\n                                  <SidebarMenuSubItem>\r\n                                    <SidebarMenuSubButton>\r\n                                      <span>Level 3.1</span>\r\n                                    </SidebarMenuSubButton>\r\n                                  </SidebarMenuSubItem>\r\n                                  <SidebarMenuSubItem>\r\n                                    <SidebarMenuSubButton>\r\n                                      <span>Level 3.2</span>\r\n                                    </SidebarMenuSubButton>\r\n                                  </SidebarMenuSubItem>\r\n                                  <Collapsible className=\"group/collapsible-3\">\r\n                                    <SidebarMenuSubItem>\r\n                                      <CollapsibleTrigger\r\n                                        nativeButton={false}\r\n                                        render={\r\n                                          <SidebarMenuSubButton className=\"w-full flex justify-between\" />\r\n                                        }\r\n                                      >\r\n                                        <span>Level 3.3</span>\r\n                                        <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-3:rotate-90\" />\r\n                                      </CollapsibleTrigger>\r\n                                      <CollapsibleContent>\r\n                                        <SidebarMenuSub className=\"ml-2 border-l border-border/50 pl-2 mt-1\">\r\n                                          <SidebarMenuSubItem>\r\n                                            <SidebarMenuSubButton>\r\n                                              <span>Level 4.1</span>\r\n                                            </SidebarMenuSubButton>\r\n                                          </SidebarMenuSubItem>\r\n                                          <SidebarMenuSubItem>\r\n                                            <SidebarMenuSubButton>\r\n                                              <span>Level 4.2</span>\r\n                                            </SidebarMenuSubButton>\r\n                                          </SidebarMenuSubItem>\r\n                                        </SidebarMenuSub>\r\n                                      </CollapsibleContent>\r\n                                    </SidebarMenuSubItem>\r\n                                  </Collapsible>\r\n                                </SidebarMenuSub>\r\n                              </CollapsibleContent>\r\n                            </SidebarMenuSubItem>\r\n                          </Collapsible>\r\n\r\n                          {/* Level 2.3 with 3.1, 3.2, 3.3 (with 4.1, 4.2) */}\r\n                          <Collapsible className=\"group/collapsible-4\">\r\n                            <SidebarMenuSubItem>\r\n                              <CollapsibleTrigger\r\n                                nativeButton={false}\r\n                                render={\r\n                                  <SidebarMenuSubButton className=\"w-full flex justify-between\" />\r\n                                }\r\n                              >\r\n                                <span>Level 2.3</span>\r\n                                <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-4:rotate-90\" />\r\n                              </CollapsibleTrigger>\r\n                              <CollapsibleContent>\r\n                                <SidebarMenuSub className=\"ml-2 border-l border-border/50 pl-2 mt-1\">\r\n                                  <SidebarMenuSubItem>\r\n                                    <SidebarMenuSubButton>\r\n                                      <span>Level 3.1</span>\r\n                                    </SidebarMenuSubButton>\r\n                                  </SidebarMenuSubItem>\r\n                                  <SidebarMenuSubItem>\r\n                                    <SidebarMenuSubButton>\r\n                                      <span>Level 3.2</span>\r\n                                    </SidebarMenuSubButton>\r\n                                  </SidebarMenuSubItem>\r\n                                  <Collapsible className=\"group/collapsible-5\">\r\n                                    <SidebarMenuSubItem>\r\n                                      <CollapsibleTrigger\r\n                                        nativeButton={false}\r\n                                        render={\r\n                                          <SidebarMenuSubButton className=\"w-full flex justify-between\" />\r\n                                        }\r\n                                      >\r\n                                        <span>Level 3.3</span>\r\n                                        <ArrowRight2 className=\"ml-auto size-4 transition-transform group-data-[state=open]/collapsible-5:rotate-90\" />\r\n                                      </CollapsibleTrigger>\r\n                                      <CollapsibleContent>\r\n                                        <SidebarMenuSub className=\"ml-2 border-l border-border/50 pl-2 mt-1\">\r\n                                          <SidebarMenuSubItem>\r\n                                            <SidebarMenuSubButton>\r\n                                              <span>Level 4.1</span>\r\n                                            </SidebarMenuSubButton>\r\n                                          </SidebarMenuSubItem>\r\n                                          <SidebarMenuSubItem>\r\n                                            <SidebarMenuSubButton>\r\n                                              <span>Level 4.2</span>\r\n                                            </SidebarMenuSubButton>\r\n                                          </SidebarMenuSubItem>\r\n                                        </SidebarMenuSub>\r\n                                      </CollapsibleContent>\r\n                                    </SidebarMenuSubItem>\r\n                                  </Collapsible>\r\n                                </SidebarMenuSub>\r\n                              </CollapsibleContent>\r\n                            </SidebarMenuSubItem>\r\n                          </Collapsible>\r\n                        </SidebarMenuSub>\r\n                      </CollapsibleContent>\r\n                    </SidebarMenuItem>\r\n                  </Collapsible>\r\n                </SidebarMenu>\r\n              </SidebarMenu>\r\n              <SidebarMenu>\r\n                <SidebarMenuItem>\r\n                  <SidebarMenuButton\r\n                    isActive={activeItem === \"sample\"}\r\n                    onClick={() => setActiveItem(\"sample\")}\r\n                    className=\"rounded-lg px-5 py-3.5 data-[active=true]:bg-primary/10 data-[active=true]:text-primary\"\r\n                  >\r\n                    <NotificationStatus className=\"size-5.5!\" variant=\"Bulk\" />\r\n                    <span className=\"font-medium\">Sample Page</span>\r\n                  </SidebarMenuButton>\r\n                </SidebarMenuItem>\r\n              </SidebarMenu>\r\n            </SidebarGroupContent>\r\n          </SidebarGroup>\r\n\r\n          {/* Upgrade Card */}\r\n          <Card className=\"my-3.75 mx-1.75 shadow-none\">\r\n            <CardContent className=\"text-center\">\r\n              <img\r\n                src={imgCoupon.src}\r\n                alt=\"Coupon\"\r\n                className=\"w-2/4 max-w-full mx-auto\"\r\n              />\r\n              <h5 className=\"mb-0 mt-1\">UIable</h5>\r\n              <p className=\"mb-4\">Checkout pro features</p>\r\n              <Button className=\"gap-2 bg-yellow-500 hover:bg-yellow-600\">\r\n                <Logout />\r\n                Upgrade to Pro\r\n              </Button>\r\n            </CardContent>\r\n          </Card>\r\n        </SidebarContent>\r\n        <SidebarRail />\r\n      </Sidebar>\r\n\r\n      {/* Main content area with navbar */}\r\n      <SidebarInset className=\"flex flex-col overflow-hidden\">\r\n        <header className=\"flex h-16 w-full shrink-0 items-center gap-1 bg-background/80 backdrop-blur-md px-4\">\r\n          <SidebarTrigger className=\"-ml-1 w-11 h-11 rounded-lg relative flex items-center justify-center mx-1\" />\r\n          <SearchBar />\r\n          <div className=\"flex-1\" />\r\n          <div className=\"flex items-center gap-2 sm:gap-4\">\r\n            <Button\r\n              variant=\"ghost\"\r\n              className=\"inline-flex items-center justify-center h-9 w-9 rounded-lg border border-transparent text-muted-foreground hover:bg-muted hover:text-primary transition-colors\"\r\n            >\r\n              <Settings className=\"size-5\" />\r\n            </Button>\r\n            <div className=\"h-4 w-px bg-border mx-1\" />\r\n            <NotificationDropdown />\r\n            <div className=\"h-4 w-px bg-border mx-1\" />\r\n            <UserProfile />\r\n          </div>\r\n        </header>\r\n\r\n        <div className=\"flex-1 overflow-y-auto\">\r\n          <div className=\"flex flex-col gap-4 p-4\">\r\n            <div className=\"grid auto-rows-min gap-4 md:grid-cols-3\">\r\n              <div className=\"aspect-video rounded-xl bg-card\" />\r\n              <div className=\"aspect-video rounded-xl bg-card\" />\r\n              <div className=\"aspect-video rounded-xl bg-card\" />\r\n            </div>\r\n            <div className=\"min-h-64 rounded-xl bg-card\" />\r\n          </div>\r\n        </div>\r\n      </SidebarInset>\r\n    </SidebarProvider>\r\n  );\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/blocks/layout/dashboard-layout/Dashboard.tsx"
    }
