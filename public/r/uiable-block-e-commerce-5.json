      "content": "// shadcn\r\nimport { Button } from \"@/components/ui/button\";\r\n\r\n// Curve Icons\r\nfunction CurveIcon() {\r\n  return (\r\n    <svg\r\n      width=\"100%\"\r\n      height=\"100%\"\r\n      viewBox=\"0 0 50 50\"\r\n      fill=\"none\"\r\n      xmlns=\"http://www.w3.org/2000/svg\"\r\n    >\r\n      <path d=\"M50 0C22.3858 0 0 22.3858 0 50V0H50Z\" fill=\"currentColor\" />\r\n    </svg>\r\n  );\r\n}\r\n\r\nconst products = [\r\n  {\r\n    image: \"https://cdn.uiable.com/block/img-furniture-4.png\",\r\n    name: \"Luxury Sofa Set\",\r\n    price: \"799\",\r\n  },\r\n  {\r\n    image: \"https://cdn.uiable.com/block/img-furniture-6.png\",\r\n    name: \"Wardrobe with TV Unit\",\r\n    price: \"999\",\r\n  },\r\n  {\r\n    image: \"https://cdn.uiable.com/block/img-furniture-5.png\",\r\n    name: \"Contemporary Dining Table\",\r\n    price: \"599\",\r\n  },\r\n];\r\n\r\n//  ------------------------------ | E - COMMERCE 5 | ------------------------------  //\r\n\r\nexport default function ecommerce5() {\r\n  return (\r\n    <div className=\"py-24 sm:py-32 bg-slate-900 overflow-hidden relative\">\r\n      <div className=\"container mx-auto px-6 lg:px-8 relative z-30\">\r\n        <div className=\"flex flex-col gap-12\">\r\n          <div className=\"max-w-2xl mx-auto flex flex-col items-center text-center gap-3\">\r\n            <p className=\"text-lg font-semibold tracking-wider text-cyan-500 uppercase\">\r\n              Premium Home Collection\r\n            </p>\r\n            <h2 className=\"text-lg sm:text-4xl font-medium text-white\">\r\n              Transform Your Living Space\r\n            </h2>\r\n            <p className=\"max-w-120 text-slate-300\">\r\n              Discover high-quality, architecturally styled furniture pieces\r\n              designed to bring warmth, comfort, and premium aesthetics into\r\n              your home.\r\n            </p>\r\n          </div>\r\n\r\n          {/* Cards Grid */}\r\n          <div className=\"grid grid-cols-12 gap-6\">\r\n            {products.map((product, index) => (\r\n              <div\r\n                key={index}\r\n                className=\"col-span-12 md:col-span-6 lg:col-span-4\"\r\n              >\r\n                <div className=\"w-full bg-slate-900 rounded-xl p-0 overflow-hidden\">\r\n                  <div className=\"group overflow-hidden rounded-lg relative\">\r\n                    <img\r\n                      src={product.image}\r\n                      alt={product.name}\r\n                      className=\"w-full group-hover:scale-125 transition-all duration-500\"\r\n                    />\r\n                    <div className=\"absolute top-0 left-0 flex flex-col items-start justify-start\">\r\n                      <div className=\"flex gap-1 items-center bg-slate-900 pr-4 py-2 rounded-br-xl\">\r\n                        <div className=\"text-slate-900 size-3 absolute right-0 top-0 translate-x-full \">\r\n                          <CurveIcon />\r\n                        </div>\r\n                        <span className=\"text-lg sm:text-2xl font-medium text-slate-300\">\r\n                          {product.name}\r\n                        </span>\r\n                      </div>\r\n                      <div className=\"flex gap-1 items-center bg-slate-900 pr-4 py-2 rounded-br-xl relative\">\r\n                        <div className=\"text-slate-900 size-3 absolute right-0 top-0 translate-x-full rotate-0\">\r\n                          <CurveIcon />\r\n                        </div>\r\n                        <div className=\"text-cardslate-900 size-3 absolute left-0 bottom-0 translate-y-full rotate-0\">\r\n                          <CurveIcon />\r\n                        </div>\r\n                        <span className=\"text-xl sm:text-5xl font-semibold text-slate-50 \">\r\n                          <span className=\"text-lg sm:text-3xl font-light\">\r\n                            $\r\n                          </span>\r\n                          {product.price}\r\n                        </span>\r\n                      </div>\r\n                    </div>\r\n                    <div className=\"absolute right-0 bottom-0 z-10\">\r\n                      <div className=\"text-slate-900 size-4 absolute left-0 bottom-0 -translate-x-full rotate-180\">\r\n                        <CurveIcon />\r\n                      </div>\r\n                      <div className=\"text-slate-900 size-4 absolute right-0 top-0 -translate-y-full rotate-180\">\r\n                        <CurveIcon />\r\n                      </div>\r\n                      <div className=\"max-w-100 bg-slate-900 rounded-tl-2xl pt-4 pl-4\">\r\n                        <Button\r\n                          size=\"lg\"\r\n                          className=\"bg-cyan-500 rounded-xl md:px-10\"\r\n                        >\r\n                          Shop Now\r\n                        </Button>\r\n                      </div>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n",
      "type": "registry:component",
