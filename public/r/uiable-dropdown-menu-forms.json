  "files": [
    {
      "path": "src/components/uiable/dropdown-menu/dropdown-menu-forms.tsx",
      "content": "// shadcn\r\nimport { Button } from \"@/components/ui/button\";\r\nimport { Checkbox } from \"@/components/ui/checkbox\";\r\nimport {\r\n  DropdownMenu,\r\n  DropdownMenuContent,\r\n  DropdownMenuItem,\r\n  DropdownMenuSeparator,\r\n  DropdownMenuTrigger\r\n} from \"@/components/ui/dropdown-menu\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport { Label } from \"@/components/ui/label\";\r\n\r\n// assets\r\nimport { ChevronDown } from \"lucide-react\";\r\n\r\n//  ------------------------------ | DROPDOWN MENU - FORMS | ------------------------------  //\r\n\r\nexport default function DropdownMenuForms() {\r\n  return (\r\n    <DropdownMenu>\r\n      <DropdownMenuTrigger\r\n        render={\r\n          <Button\r\n            variant=\"default\"\r\n            className=\"bg-green-600 hover:bg-green-700 text-white\"\r\n          >\r\n            Forms <ChevronDown className=\"ml-2 h-4 w-4\" />\r\n          </Button>\r\n        }\r\n      />\r\n      <DropdownMenuContent align=\"start\" className=\"w-64 p-6\">\r\n        <form className=\"space-y-4\" onSubmit={(e) => e.preventDefault()}>\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"email\">Email Address</Label>\r\n            <Input id=\"email\" type=\"email\" placeholder=\"email@example.com\" />\r\n          </div>\r\n          <div className=\"space-y-2\">\r\n            <Label htmlFor=\"password\">Password</Label>\r\n            <Input id=\"password\" type=\"password\" placeholder=\"Password\" />\r\n          </div>\r\n          <div className=\"flex items-center space-x-2\">\r\n            <Checkbox id=\"remember\" />\r\n            <Label htmlFor=\"remember\" className=\"text-xs font-normal\">\r\n              Remember me\r\n            </Label>\r\n          </div>\r\n          <div className=\"grid grid-cols-2 gap-2\">\r\n            <Button type=\"submit\">Sign in</Button>\r\n            <Button type=\"reset\" variant=\"secondary\">\r\n              Reset\r\n            </Button>\r\n          </div>\r\n        </form>\r\n        <DropdownMenuSeparator className=\"my-4\" />\r\n        <DropdownMenuItem>\r\n          New here? <a href=\"#\">Sign up</a>\r\n        </DropdownMenuItem>\r\n        <DropdownMenuItem>\r\n          <a href=\"#\">Forgot password?</a>\r\n        </DropdownMenuItem>\r\n      </DropdownMenuContent>\r\n    </DropdownMenu>\r\n  );\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/dropdown-menu/dropdown-menu-forms.tsx"
    }
  ],
  "categories": [
    "dropdown-menu"
  ],
  "type": "registry:ui"
}