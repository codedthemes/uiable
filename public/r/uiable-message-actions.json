      "content": "// shadcn\r\nimport { Bubble, BubbleContent } from \"@/components/ui/bubble\"\r\nimport { Button } from \"@/components/ui/button\"\r\nimport { Message, MessageContent, MessageFooter } from \"@/components/ui/message\"\r\n\r\n// assets\r\nimport {\r\n  CopyIcon,\r\n  RefreshCcwIcon,\r\n  ThumbsDownIcon,\r\n  ThumbsUpIcon,\r\n} from \"lucide-react\"\r\n\r\n//  ------------------------------ | MESSAGE - ACTIONS | ------------------------------  //\r\n\r\nexport function MessageActions() {\r\n  return (\r\n    <div className=\"flex w-full max-w-sm flex-col gap-8\">\r\n      <Message>\r\n        <MessageContent>\r\n          <Bubble variant=\"muted\">\r\n            <BubbleContent>\r\n              The install failure is coming from the workspace package.\r\n            </BubbleContent>\r\n          </Bubble>\r\n          <MessageFooter>\r\n            <Button variant=\"ghost\" size=\"icon\" aria-label=\"Copy\" title=\"Copy\">\r\n              <CopyIcon />\r\n            </Button>\r\n            <Button variant=\"ghost\" size=\"icon\" aria-label=\"Like\" title=\"Like\">\r\n              <ThumbsUpIcon />\r\n            </Button>\r\n            <Button\r\n              variant=\"ghost\"\r\n              size=\"icon\"\r\n              aria-label=\"Dislike\"\r\n              title=\"Dislike\"\r\n            >\r\n              <ThumbsDownIcon />\r\n            </Button>\r\n          </MessageFooter>\r\n        </MessageContent>\r\n      </Message>\r\n      <Message align=\"end\">\r\n        <MessageContent>\r\n          <Bubble>\r\n            <BubbleContent className=\"dark:text-white\">\r\n              Okay drop me a link. Taking a look...\r\n            </BubbleContent>\r\n          </Bubble>\r\n          <MessageFooter className=\"gap-2\">\r\n            <span className=\"font-normal text-destructive\">Failed to send</span>\r\n            <Button\r\n              variant=\"ghost\"\r\n              size=\"icon-xs\"\r\n              title=\"Retry\"\r\n              aria-label=\"Retry\"\r\n            >\r\n              <RefreshCcwIcon />\r\n            </Button>\r\n          </MessageFooter>\r\n        </MessageContent>\r\n      </Message>\r\n    </div>\r\n  )\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/message/message-actions.tsx"
    }
  ],
