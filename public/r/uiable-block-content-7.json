      "content": "// shadcn\r\nimport { Button } from \"@/components/ui/button\";\r\n\r\n// assets\r\n\r\n//  ------------------------------- | CONTENT 7 | -------------------------------  //\r\n\r\nexport default function Content7() {\r\n  const features = [\r\n    {\r\n      title: \"Learn\",\r\n      subtitle: \"Understand the Basics\",\r\n      colorClass: \"bg-blue-500\",\r\n      description:\r\n        \"Start by learning the fundamentals of video editing, tools, and workflow. Understand timelines, cuts, transitions, audio, and basic editing techniques.\",\r\n    },\r\n    {\r\n      title: \"Practice\",\r\n      subtitle: \"Apply Your Skills\",\r\n      colorClass: \"bg-pink-500\",\r\n      description:\r\n        \"Practice editing with real projects and hands-on exercises. Improve creativity by working with effects, text animation, color correction, and sound design.\",\r\n    },\r\n    {\r\n      title: \"Master\",\r\n      subtitle: \"Become a Professional Creator\",\r\n      colorClass: \"bg-lime-500\",\r\n      description:\r\n        \"Master advanced editing techniques and professional workflows. Create high-quality cinematic videos for YouTube, social media, and commercial projects with confidence.\",\r\n    },\r\n  ];\r\n\r\n  return (\r\n    <section className=\"py-24 sm:py-32 \">\r\n      <div className=\"container mx-auto px-4 sm:px-6 lg:px-8\">\r\n        <div className=\"flex flex-col gap-5 sm:gap-12 items-center\">\r\n          <div className=\"flex flex-col gap-4 sm:gap-6 items-center text-center\">\r\n            <h2 className=\"text-lg sm:text-3xl font-medium text-slate-800 dark:text-slate-50\">\r\n              Master Video Editing from Scratch\r\n            </h2>\r\n            <p className=\"max-w-150 text-slate-600 dark:text-slate-100\">\r\n              Learn step-by-step video editing techniques, transitions, effects,\r\n              audio syncing, and exporting professional-quality videos — perfect\r\n              for beginners.\r\n            </p>\r\n          </div>\r\n          <div className=\"group bg-card rounded-2xl shadow-[0_0_40px_-8px_#4680ff38] p-2 max-w-150 mx-auto\">\r\n            <div className=\"relative rounded-xl overflow-hidden\">\r\n              <img\r\n                src=\"https://cdn.uiable.com/block/img-content-6.jpg\"\r\n                alt=\"Team meeting in a conference room\"\r\n                className=\"w-full group-hover:scale-125 transition-all duration-300\"\r\n              />\r\n              <div className=\"absolute inset-0 flex items-center justify-center ease-[cubic-bezier(0.175,0.885,0.32,1.275)] duration-300 group-hover:backdrop-blur-md\">\r\n                <Button\r\n                  className=\"size-12 sm:size-16 rounded-full p-0 bg-sky-500 text-white transition-all group-hover:scale-125 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] duration-300\"\r\n                  aria-label=\"Play video\"\r\n                >\r\n                  <svg\r\n                    className=\"size-8 transition-all duration-300\"\r\n                    xmlns=\"http://www.w3.org/2000/svg\"\r\n                    viewBox=\"0 0 24 24\"\r\n                    fill=\"none\"\r\n                  >\r\n                    <path\r\n                      d=\"M18.7 8.98 4.14 17.71c-.09-.33-.14-.68-.14-1.04V7.33c0-3.08 3.33-5 6-3.46l4.04 2.33 4.05 2.34c.22.13.43.27.61.44Z\"\r\n                      fill=\"currentColor\"\r\n                    ></path>\r\n                    <path\r\n                      opacity=\".4\"\r\n                      d=\"m18.089 15.46-4.05 2.34-4.04 2.33c-1.91 1.1-4.16.44-5.28-1.17l.42-.25 14.44-8.66c1 1.8.51 4.26-1.49 5.41Z\"\r\n                      fill=\"currentColor\"\r\n                    ></path>\r\n                  </svg>\r\n                </Button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"grid grid-cols-12 gap-6\">\r\n            {features.map((feature, idx) => (\r\n              <div key={idx} className=\"col-span-12 lg:col-span-4\">\r\n                <div className=\"flex flex-row gap-6\">\r\n                  <div className=\"shrink-0 relative\">\r\n                    <div\r\n                      className={\r\n                        \"size-12 md:size-14 rounded-xl \" +\r\n                        feature.colorClass +\r\n                        \" text-white flex items-center justify-center relative z-10\"\r\n                      }\r\n                    >\r\n                      <span className=\"text-xl leading-none font-semibold\">\r\n                        0{idx + 1}\r\n                      </span>\r\n                    </div>\r\n                    <span\r\n                      className={\r\n                        \"absolute inset-0 z-0 size-12 md:size-14 blur-md scale-110 opacity-40 \" +\r\n                        feature.colorClass +\r\n                        \" block rounded-xl\"\r\n                      }\r\n                    ></span>\r\n                  </div>\r\n                  <div className=\"grow\">\r\n                    <div className=\"flex flex-col gap-4 relative z-40\">\r\n                      <div className=\"flex flex-col gap-1\">\r\n                        <h2 className=\"text-lg sm:text-2xl font-medium text-slate-800 dark:text-slate-50\">\r\n                          {feature.title}\r\n                        </h2>\r\n                        <p className=\"text-base sm:text-lg text-slate-400 dark:text-slate-500 font-semibold\">\r\n                          {feature.subtitle}\r\n                        </p>\r\n                      </div>\r\n                      <p className=\"text-slate-600 dark:text-slate-100\">\r\n                        {feature.description}\r\n                      </p>\r\n                    </div>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            ))}\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </section>\r\n  );\r\n}\r\n",
