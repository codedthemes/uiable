      "content": "// shadcn\r\nimport {\r\n  Combobox,\r\n  ComboboxContent,\r\n  ComboboxEmpty,\r\n  ComboboxInput,\r\n  ComboboxItem,\r\n  ComboboxList,\r\n} from \"@/components/ui/combobox\"\r\n\r\n// assets\r\nimport { SearchX } from \"lucide-react\"\r\n\r\n// constants\r\nconst frameworks = [\r\n  \"Next.js\",\r\n  \"SvelteKit\",\r\n  \"Nuxt.js\",\r\n  \"Remix\",\r\n  \"Astro\",\r\n] as const\r\n\r\n//  ------------------------------ | COMBOBOX - ERROR | ------------------------------  //\r\n\r\nexport function ComboboxError() {\r\n  return (\r\n    <Combobox items={frameworks}>\r\n      <ComboboxInput placeholder=\"Select a framework\" />\r\n      <ComboboxContent>\r\n        <ComboboxEmpty className=\"flex-col items-center justify-center gap-3 p-6 text-center\">\r\n          <div className=\"flex size-10 items-center justify-center rounded-lg bg-destructive/10 text-destructive dark:bg-destructive/20\">\r\n            <SearchX className=\"size-5\" />\r\n          </div>\r\n          <div className=\"space-y-1\">\r\n            <p className=\"text-sm font-semibold text-foreground\">\r\n              No results found\r\n            </p>\r\n            <p className=\"max-w-[200px] text-xs text-muted-foreground\">\r\n              We couldn't find anything matching your search query.\r\n            </p>\r\n          </div>\r\n        </ComboboxEmpty>\r\n        <ComboboxList>\r\n          {(item) => (\r\n            <ComboboxItem key={item} value={item}>\r\n              {item}\r\n            </ComboboxItem>\r\n          )}\r\n        </ComboboxList>\r\n      </ComboboxContent>\r\n    </Combobox>\r\n  )\r\n}\r\n",
      "type": "registry:component",
      "target": "@components/uiable/combobox/combobox-error.tsx"
    }
