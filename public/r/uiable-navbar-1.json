{
  "$schema": "https://ui.shadcn.com/schema/registry-item.json",
  "name": "uiable-navbar-1",
  "title": "Navbar 1",
  "description": "Navbar variant 1.",
  "files": [
    {
      "path": "src/components/uiable/blocks/navbar/navbar-1.tsx",
      "content": "\"use client\";\r\n\r\nimport { useState } from \"react\";\r\n\r\n// shadcn\r\nimport { Avatar, AvatarFallback, AvatarImage } from \"@/components/ui/avatar\";\r\nimport { Badge } from \"@/components/ui/badge\";\r\nimport { Button } from \"@/components/ui/button\";\r\nimport {\r\n  DropdownMenu,\r\n  DropdownMenuContent,\r\n  DropdownMenuGroup,\r\n  DropdownMenuItem,\r\n  DropdownMenuLabel,\r\n  DropdownMenuSeparator,\r\n  DropdownMenuTrigger\r\n} from \"@/components/ui/dropdown-menu\";\r\nimport { ScrollArea } from \"@/components/ui/scroll-area\";\r\nimport {\r\n  Sheet,\r\n  SheetContent,\r\n  SheetHeader,\r\n  SheetTitle,\r\n  SheetTrigger\r\n} from \"@/components/ui/sheet\";\r\n\r\n// project\r\nimport ComponentList from \"@/components/uiable/layout/component-list\";\r\nimport ComponentSearch from \"@/components/uiable/layout/shared/component-search\";\r\nimport Logo from \"@/components/uiable/layout/shared/logo\";\r\nimport MobileNav from \"@/components/uiable/layout/shared/mobile-nav\";\r\n\r\n// assets\r\nimport {\r\n  Bell,\r\n  FolderGit2,\r\n  Layout,\r\n  LogOut,\r\n  Menu,\r\n  Settings,\r\n  ShoppingCart,\r\n  User\r\n} from \"lucide-react\";\r\n\r\n// ── Dummy data ──────────────────────────────────────────────────────────────\r\nconst DUMMY_NOTIFICATIONS = [\r\n  {\r\n    id: 1,\r\n    title: \"New comment on your post\",\r\n    description: 'Alex left a comment: \"Great work!\"',\r\n    time: \"2 min ago\",\r\n    read: false\r\n  },\r\n  {\r\n    id: 2,\r\n    title: \"Your export is ready\",\r\n    description: \"The CSV export you requested is ready to download.\",\r\n    time: \"15 min ago\",\r\n    read: false\r\n  },\r\n  {\r\n    id: 3,\r\n    title: \"Server restarted\",\r\n    description: \"Production server restarted successfully.\",\r\n    time: \"1 hr ago\",\r\n    read: true\r\n  },\r\n  {\r\n    id: 4,\r\n    title: \"New user registered\",\r\n    description: \"Sarah Jones just created an account.\",\r\n    time: \"3 hr ago\",\r\n    read: true\r\n  }\r\n];\r\n\r\n//  ------------------------------ | COMPONENT - HEADER | ------------------------------  //\r\n\r\nexport default function Navbar1() {\r\n  const [isMenuOpen, setIsMenuOpen] = useState(false);\r\n  const [isComponentsOpen, setIsComponentsOpen] = useState(false);\r\n  const [search, setSearch] = useState(\"\");\r\n\r\n  const unreadCount = DUMMY_NOTIFICATIONS.filter((n) => !n.read).length;\r\n\r\n  return (\r\n    <header className=\"sticky top-0 z-50 w-full bg-card/70 backdrop-blur-md shadow-[0_0_24px_rgba(27,46,94,.05)] dark:shadow-[0_0_24px_rgba(27,46,94,.05)]\">\r\n      <div className=\"container flex py-4 items-center justify-between px-4 sm:px-8 mx-auto\">\r\n        <div className=\"flex items-center gap-2 sm:gap-8\">\r\n          <Logo />\r\n        </div>\r\n\r\n        <div className=\"flex items-center gap-2 sm:gap-4\">\r\n          <nav className=\"hidden md:flex items-center gap-6\">\r\n            <a\r\n              href=\"#\"\r\n              className=\"text-base font-medium text-muted-foreground hover:text-primary transition-colors\"\r\n            >\r\n              Dashboard\r\n            </a>\r\n            <a\r\n              href=\"#\"\r\n              className=\"text-base font-medium text-muted-foreground hover:text-primary transition-colors\"\r\n            >\r\n              Components\r\n            </a>\r\n            <a\r\n              href=\"#\"\r\n              className=\"text-base font-medium text-muted-foreground hover:text-primary transition-colors\"\r\n            >\r\n              Blocks\r\n            </a>\r\n            <a\r\n              href=\"#\"\r\n              className=\"text-base font-medium text-muted-foreground hover:text-primary transition-colors\"\r\n            >\r\n              Documentation\r\n            </a>\r\n          </nav>\r\n          <div className=\"h-6 w-px bg-border mx-2 hidden sm:block\" />\r\n          {/* Mobile Components Toggle */}\r\n          <Sheet open={isComponentsOpen} onOpenChange={setIsComponentsOpen}>\r\n            <SheetTrigger className=\"lg:hidden h-9 px-3 gap-2 border-primary/20 text-primary hover:bg-primary/5\">\r\n              <Layout className=\"h-4 w-4\" />\r\n              <span className=\"hidden xs:inline\">Components</span>\r\n            </SheetTrigger>\r\n            {/*  */}\r\n            <SheetContent\r\n              side=\"left\"\r\n              className=\"w-80 p-0 bg-card gap-0 *:data-[slot=sheet-close]:top-8\"\r\n            >\r\n              <SheetHeader className=\"p-6 border-b text-left ltr:pr-10 rtl:pl-10\">\r\n                <ComponentSearch value={search} onChange={setSearch} />\r\n              </SheetHeader>\r\n              <ScrollArea className=\"h-[calc(100vh-100px)] px-4 py-6\">\r\n                <ComponentList\r\n                  search={search}\r\n                  onSelect={() => setIsComponentsOpen(false)}\r\n                />\r\n              </ScrollArea>\r\n            </SheetContent>\r\n          </Sheet>\r\n          {/* Mobile Menu Toggle */}\r\n          <Sheet open={isMenuOpen} onOpenChange={setIsMenuOpen}>\r\n            <SheetTrigger className=\"lg:hidden h-9 px-3 gap-2 border-primary/20 text-primary hover:bg-primary/5\">\r\n              <Menu className=\"h-5 w-5\" />\r\n              <span className=\"sr-only\">Toggle Menu</span>\r\n            </SheetTrigger>\r\n            <SheetContent\r\n              side=\"right\"\r\n              className=\"w-72 p-0 bg-card *:data-[slot=sheet-close]:top-6\"\r\n            >\r\n              <SheetTitle className=\"px-6 pt-6\">\r\n                <Logo />\r\n              </SheetTitle>\r\n              <div className=\"flex flex-col gap-4 p-6\">\r\n                <MobileNav onSelect={() => setIsMenuOpen(false)} />\r\n                <div className=\"pt-4 border-t flex flex-col gap-3\">\r\n                  <Button\r\n                    variant=\"default\"\r\n                    className=\"gap-2\"\r\n                    onClick={() => {}}\r\n                  >\r\n                    <ShoppingCart className=\"h-4 w-4\" />\r\n                    <span>Purchase Now</span>\r\n                  </Button>\r\n                  <a\r\n                    href=\"#\"\r\n                    className=\"flex items-center gap-2 px-3 py-2 text-sm font-medium text-muted-foreground hover:text-foreground\"\r\n                  >\r\n                    <FolderGit2 className=\"h-4 w-4\" />\r\n                    <span>GitHub Repository</span>\r\n                  </a>\r\n                </div>\r\n              </div>\r\n            </SheetContent>\r\n          </Sheet>\r\n          <div className=\"hidden sm:flex items-center gap-2\">\r\n            {/* Settings (dummy - no events) */}\r\n            <Button\r\n              variant=\"ghost\"\r\n              size=\"icon\"\r\n              className=\"inline-flex items-center justify-center h-9 w-9 rounded-lg border border-transparent text-muted-foreground hover:bg-muted hover:text-primary transition-colors\"\r\n            >\r\n              <Settings className=\"size-5\" />\r\n            </Button>\r\n\r\n            {/* Notification Bell */}\r\n            <DropdownMenu>\r\n              <DropdownMenuTrigger className=\"relative inline-flex items-center justify-center h-9 w-9 rounded-lg border border-transparent text-muted-foreground hover:bg-muted hover:text-primary transition-colors\">\r\n                <Bell className=\"size-5\" />\r\n                {unreadCount > 0 && (\r\n                  <Badge className=\"absolute -top-1 -right-1 h-4 w-4 min-w-0 p-0 flex items-center justify-center text-[10px] bg-red-500 hover:bg-red-500 rounded-full\">\r\n                    {unreadCount}\r\n                  </Badge>\r\n                )}\r\n              </DropdownMenuTrigger>\r\n              <DropdownMenuContent align=\"end\" className=\"w-80\">\r\n                <DropdownMenuGroup>\r\n                  <DropdownMenuLabel className=\"flex items-center justify-between\">\r\n                    <span>Notifications</span>\r\n                    {unreadCount > 0 && (\r\n                      <Badge variant=\"secondary\" className=\"text-xs\">\r\n                        {unreadCount} new\r\n                      </Badge>\r\n                    )}\r\n                  </DropdownMenuLabel>\r\n                  <DropdownMenuSeparator />\r\n                  {DUMMY_NOTIFICATIONS.map((notification) => (\r\n                    <DropdownMenuItem\r\n                      key={notification.id}\r\n                      className=\"flex flex-col items-start gap-1 py-3 cursor-pointer\"\r\n                    >\r\n                      <div className=\"flex items-center justify-between w-full gap-2\">\r\n                        <span\r\n                          className={`text-sm font-medium ${!notification.read ? \"text-foreground\" : \"text-muted-foreground\"}`}\r\n                        >\r\n                          {notification.title}\r\n                        </span>\r\n                        {!notification.read && (\r\n                          <span className=\"h-2 w-2 rounded-full bg-blue-500 shrink-0\" />\r\n                        )}\r\n                      </div>\r\n                      <span className=\"text-xs text-muted-foreground line-clamp-1\">\r\n                        {notification.description}\r\n                      </span>\r\n                      <span className=\"text-xs text-muted-foreground/70\">\r\n                        {notification.time}\r\n                      </span>\r\n                    </DropdownMenuItem>\r\n                  ))}\r\n                  <DropdownMenuSeparator />\r\n                  <DropdownMenuItem className=\"justify-center text-sm text-primary cursor-pointer\">\r\n                    View all notifications\r\n                  </DropdownMenuItem>\r\n                </DropdownMenuGroup>\r\n              </DropdownMenuContent>\r\n            </DropdownMenu>\r\n\r\n            {/* GitHub Link */}\r\n            <a\r\n              href=\"#\"\r\n              className=\"inline-flex items-center justify-center h-9 w-9 rounded-lg border border-transparent text-muted-foreground hover:bg-muted hover:text-primary transition-colors\"\r\n            >\r\n              <FolderGit2 className=\"size-5\" />\r\n            </a>\r\n\r\n            {/* Profile Dropdown */}\r\n            <DropdownMenu>\r\n              <DropdownMenuTrigger className=\"inline-flex items-center justify-center h-9 w-9 rounded-full p-0 ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2\">\r\n                <Avatar className=\"h-8 w-8\">\r\n                  <AvatarImage\r\n                    src=\"https://github.com/shadcn.png\"\r\n                    alt=\"User avatar\"\r\n                  />\r\n                  <AvatarFallback>JD</AvatarFallback>\r\n                </Avatar>\r\n              </DropdownMenuTrigger>\r\n              <DropdownMenuContent align=\"end\" className=\"w-56\">\r\n                <DropdownMenuGroup>\r\n                  <DropdownMenuLabel>\r\n                    <div className=\"flex flex-col gap-1\">\r\n                      <span className=\"text-sm font-medium\">John Doe</span>\r\n                      <span className=\"text-xs text-muted-foreground\">\r\n                        john.doe@example.com\r\n                      </span>\r\n                    </div>\r\n                  </DropdownMenuLabel>\r\n                  <DropdownMenuSeparator />\r\n                  <DropdownMenuItem className=\"gap-2 cursor-pointer\">\r\n                    <User className=\"h-4 w-4\" />\r\n                    <span>Profile</span>\r\n                  </DropdownMenuItem>\r\n                  <DropdownMenuSeparator />\r\n                  <DropdownMenuItem className=\"gap-2 cursor-pointer text-red-500 focus:text-red-500\">\r\n                    <LogOut className=\"h-4 w-4\" />\r\n                    <span>Log out</span>\r\n                  </DropdownMenuItem>\r\n                </DropdownMenuGroup>\r\n              </DropdownMenuContent>\r\n            </DropdownMenu>\r\n\r\n            <Button\r\n              className=\"bg-green-500 hover:bg-green-500/90 gap-2\"\r\n              onClick={() => {}}\r\n            >\r\n              <ShoppingCart className=\"size-5\" />\r\n              <span>Purchase Now</span>\r\n            </Button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </header>\r\n  );\r\n}\r\n",
      "type": "registry:component",
      "target": "@@components/uiable/blocks/navbar/navbar-1.tsx"
    }
  ],
  "categories": [
    "navbar"
  ],
  "type": "registry:block"
}