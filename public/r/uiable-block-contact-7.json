                   placeholder=\"name@example.com\"\r\n                    />\r\n                  </Field>\r\n                  <Field>\r\n                    <FieldLabel htmlFor=\"textarea-header-footer-12\">\r\n                      Messege\r\n                    </FieldLabel>\r\n                    <Textarea\r\n                      id=\"textarea-header-footer-12\"\r\n                      placeholder=\"Enter your text here...\"\r\n                    />\r\n                  </Field>\r\n                  <Field orientation=\"horizontal\" className=\"justify-center\">\r\n                    <Button\r\n                      type=\"reset\"\r\n                      size=\"lg\"\r\n                      variant=\"outline\"\r\n                      className=\"bg-card rounded-full\"\r\n                    >\r\n                      Reset\r\n                    </Button>\r\n                    <Button\r\n                      type=\"submit\"\r\n                      size=\"lg\"\r\n                      className=\"rounded-full shadow-[0_4px_6px_-2px_#b6c0dbd9] hover:shadow-none dark:shadow-none transition-all\"\r\n                    >\r\n                      Get Started\r\n                    </Button>\r\n                  </Field>\r\n                </FieldGroup>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div className=\"w-full basis-full lg:basis-5/12\"></div>\r\n        </div>\r\n      </div>\r\n      <div className=\"lg:absolute lg:right-0 lg:inset-y-0 w-full lg:w-2/4 max-lg:h-76 z-20\">\r\n        <iframe\r\n          src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d14875.987145437051!2d72.86633095391547!3d21.231976027219776!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be04f0778f12ea7%3A0xd4bc1f45fa091301!2sSurat%20Digital%20Valley!5e0!3m2!1sen!2sin!4v1779250060915!5m2!1sen!2sin\"\r\n          width=\"100%\"\r\n          height=\"100%\"\r\n          allowFullScreen\r\n          loading=\"lazy\"\r\n          